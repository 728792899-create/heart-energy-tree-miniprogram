page {
  --v3-color-bg-app: #FFFDF7;
  --v3-color-bg-elevated: #FFFFFF;
  --v3-color-bg-subtle: #FBF6EB;
  --v3-color-text-primary: #242920;
  --v3-color-text-secondary: #596057;
  --v3-color-text-tertiary: #7C837A;
  --v3-color-action-primary: #2E452C;
  --v3-color-action-secondary: #EEF3EA;
  --v3-color-border: #E8E1D3;
  --v3-color-success: #DCE8D5;
  --v3-color-pending: #F4ECD1;
  --v3-color-danger: #F5E1D4;
  --v3-radius-card: 36rpx;
  --v3-radius-control: 24rpx;
  --v3-shadow-card: 0 16rpx 38rpx rgba(36, 41, 32, 0.07);
  min-height: 100%;
  overflow-x: hidden;
  background: #FFFDF7;
  color: #242920;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  letter-spacing: 0;
}

view,
text,
image,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

image {
  max-width: 100%;
}

button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  max-width: 100%;
  padding: 0 28rpx;
  border-radius: 28rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.25;
  transition: transform 160ms ease, opacity 160ms ease;
}

button::after {
  border: 0;
}

button[disabled] {
  opacity: 0.58;
}

[role="button"] {
  min-width: 88rpx;
  min-height: 88rpx;
}

.page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow-x: hidden;
  padding: 28rpx 28rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 92% 4%, rgba(135, 97, 77, 0.09) 0, rgba(135, 97, 77, 0) 220rpx),
    radial-gradient(circle at 6% 34%, rgba(63, 101, 72, 0.08) 0, rgba(63, 101, 72, 0) 180rpx),
    #FFFDF7;
}

.page::before {
  content: "";
  position: fixed;
  z-index: -1;
  inset: 0;
  pointer-events: none;
  opacity: 0.18;
  background-image: radial-gradient(rgba(63, 101, 72, 0.16) 0.7rpx, transparent 0.7rpx);
  background-size: 18rpx 18rpx;
}

.band {
  position: relative;
  overflow: hidden;
  margin: 0 -28rpx 30rpx;
  padding: 34rpx 28rpx;
  background: linear-gradient(145deg, #FFFDF7 0%, #E7EFE4 64%, #FBF6EB 100%);
  border-top: 1rpx solid rgba(135, 97, 77, 0.2);
  border-bottom: 1rpx solid rgba(63, 101, 72, 0.13);
}

.band::after {
  content: "♡";
  position: absolute;
  right: 24rpx;
  bottom: -22rpx;
  color: rgba(63, 101, 72, 0.08);
  font-size: 150rpx;
  line-height: 1;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 34rpx 0 18rpx;
  color: #2E452C;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.section-title::before {
  content: "";
  flex: 0 0 8rpx;
  width: 8rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2E452C, #9A715B);
}

.first-title {
  margin-top: 0;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(135, 97, 77, 0.52);
  border-radius: 999rpx;
  color: #3F6548;
  background: rgba(255, 249, 245, 0.78);
  font-size: 21rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.muted {
  color: #596057;
}

.small {
  font-size: 24rpx;
  line-height: 1.55;
}

.tiny {
  font-size: 21rpx;
  line-height: 1.45;
}

.money {
  color: #2E452C;
  font-size: 52rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
}

.row-between > view:first-child,
.row-between > text:first-child {
  min-width: 0;
  flex: 1 1 auto;
  overflow-wrap: anywhere;
}

.row-between > view:last-child,
.row-between > text:last-child {
  min-width: 0;
  flex: 0 0 auto;
}

.grid-2 {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
}

.card {
  position: relative;
  overflow: hidden;
  min-width: 0;
  padding: 26rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.46);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 16rpx 42rpx rgba(63, 101, 72, 0.075);
}

.card::after {
  content: "";
  position: absolute;
  pointer-events: none;
  right: -46rpx;
  top: -52rpx;
  width: 118rpx;
  height: 118rpx;
  border: 1rpx solid rgba(135, 97, 77, 0.2);
  border-radius: 50%;
}

.card-title {
  color: #242920;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.35;
}

.floaty {
  animation: float-card 3s ease-in-out infinite;
}

.tap-pop:active,
.primary-btn:active,
.secondary-btn:active,
.ghost-btn:active,
.danger-btn:active {
  transform: scale(0.985);
}

.primary-btn {
  min-height: 88rpx;
  color: #FFFFFF;
  background: #2E452C;
  box-shadow: 0 14rpx 30rpx rgba(63, 101, 72, 0.22);
}

.secondary-btn {
  min-height: 88rpx;
  color: #2E452C;
  background: #EEF3EA;
  border: 1rpx solid rgba(63, 101, 72, 0.12);
}

.ghost-btn {
  min-height: 88rpx;
  color: #3F6548;
  background: #E7EFE4;
  border: 1rpx solid rgba(43, 68, 41, 0.14);
}

.danger-btn {
  min-height: 88rpx;
  color: #704A39;
  background: #F5E1D4;
  border: 1rpx solid rgba(181, 66, 75, 0.16);
}

.input,
.textarea {
  width: 100%;
  min-width: 0;
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(63, 101, 72, 0.17);
  border-radius: 24rpx;
  color: #242920;
  background: #FFFFFF;
}

.textarea {
  min-height: 164rpx;
  line-height: 1.6;
}

.input:focus,
.textarea:focus {
  border-color: #87614D;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #2E452C;
  background: #EEF3EA;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.status-submitted {
  color: #78540F;
  background: #F4ECD1;
}

.status-approved {
  color: #25613E;
  background: #DCE8D5;
}

.status-rejected {
  color: #704A39;
  background: #F5E1D4;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-width: 0;
}

.empty,
.error-panel,
.loading-panel {
  padding: 46rpx 28rpx;
  border-radius: 28rpx;
  text-align: center;
  line-height: 1.65;
}

.empty {
  color: #596057;
  border: 2rpx dashed rgba(63, 101, 72, 0.24);
  background: rgba(248, 230, 236, 0.48);
}

.error-panel {
  color: #704A39;
  border: 1rpx solid rgba(181, 66, 75, 0.18);
  background: #F5E1D4;
}

.loading-panel {
  color: #3F6548;
  border: 1rpx solid rgba(63, 101, 72, 0.1);
  background: rgba(255, 253, 250, 0.92);
}

.skeleton-line {
  overflow: hidden;
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #E7EFE4 25%, #FFFDF7 50%, #E7EFE4 75%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.4s linear infinite;
}

.soft-hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(145deg, #FFFDF7 0%, #E7EFE4 62%, #FFF0DA 100%);
}

.soft-hero::before,
.soft-hero::after {
  content: "";
  position: absolute;
  width: 120rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  animation: drift 5.2s ease-in-out infinite;
}

.soft-hero::before {
  top: 28rpx;
  right: 110rpx;
}

.soft-hero::after {
  bottom: 26rpx;
  left: 40rpx;
  animation-delay: -2.1s;
}

.paper-card {
  border: 1rpx solid rgba(135, 97, 77, 0.28);
  background: linear-gradient(150deg, #FFFFFF, #FFFDF7);
  box-shadow: 0 18rpx 42rpx rgba(92, 64, 53, 0.07);
}

.love-ribbon {
  display: inline-flex;
  min-height: 42rpx;
  align-items: center;
  padding: 0 16rpx;
  border-radius: 8rpx 999rpx 999rpx 8rpx;
  color: #FFFFFF;
  background: #3F6548;
  font-size: 21rpx;
  font-weight: 800;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

@keyframes float-card {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

@keyframes drift {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(22rpx); }
}

@keyframes pulse-soft {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.035); }
}

@keyframes skeleton-shimmer {
  from { background-position: 200% 0; }
  to { background-position: -200% 0; }
}

@media (prefers-reduced-motion: reduce) {
  button {
    transition: none;
  }

  .floaty,
  .skeleton-line,
  .soft-hero::before,
  .soft-hero::after {
    animation: none;
    transform: none;
  }
}
