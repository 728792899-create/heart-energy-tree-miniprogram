.celebration-backdrop {
  position: fixed;
  z-index: 999;
  inset: 0;
  padding: 42rpx 30rpx calc(42rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(69, 52, 58, 0.52);
  backdrop-filter: blur(10rpx);
}

.celebration-sheet {
  overflow: hidden;
  width: 100%;
  max-width: 650rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(212, 174, 106, 0.42);
  border-radius: 36rpx;
  text-align: center;
  background: #fff9f5;
  box-shadow: 0 32rpx 80rpx rgba(69, 52, 58, 0.24);
  animation: celebration-in 420ms cubic-bezier(.18,.8,.2,1) both;
}

.celebration-title {
  margin-top: 20rpx;
  color: #7d2f49;
  font-size: 35rpx;
  font-weight: 900;
}

.celebration-message {
  margin: 12rpx 12rpx 0;
  color: #6c585f;
  font-size: 24rpx;
  line-height: 1.65;
}

.celebration-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin-top: 24rpx;
  color: #fff;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #b74465, #d45f7e);
  font-size: 26rpx;
  font-weight: 850;
}

@keyframes celebration-in {
  from { opacity: 0; transform: translateY(44rpx) scale(0.92); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
