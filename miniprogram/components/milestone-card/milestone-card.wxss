.milestone-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  border: 1rpx solid rgba(135, 97, 77, 0.34);
  border-radius: 30rpx;
  background: linear-gradient(150deg, #FFFDF7, #FBF6EB 54%, #E7EFE4);
  box-shadow: 0 16rpx 38rpx rgba(63, 101, 72, 0.075);
}

.gold-ribbon {
  display: inline-flex;
  min-height: 40rpx;
  align-items: center;
  padding: 0 15rpx;
  border-radius: 8rpx 999rpx 999rpx 8rpx;
  color: #6a4d22;
  background: #f3dfb8;
  font-size: 20rpx;
  font-weight: 800;
}

.scene-icon {
  position: absolute;
  right: 26rpx;
  top: 20rpx;
  color: #3F6548;
  font-size: 52rpx;
}

.milestone-title {
  margin-top: 18rpx;
  color: #3F6548;
  font-size: 31rpx;
  font-weight: 900;
}

.milestone-message {
  margin-top: 10rpx;
  color: #66535a;
  font-size: 24rpx;
  line-height: 1.65;
}

.accept-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin-top: 22rpx;
  color: #3F6548;
  background: rgba(248, 230, 236, 0.9);
  border-radius: 26rpx;
  font-size: 25rpx;
  font-weight: 800;
}
