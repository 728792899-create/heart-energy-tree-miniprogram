.state-panel {
  width: 100%;
  padding: 44rpx 30rpx;
  border: 1rpx solid #E8E1D3;
  border-radius: 36rpx;
  text-align: center;
  background: linear-gradient(155deg, #FFFFFF, #EEF3EA);
  box-shadow: 0 16rpx 38rpx rgba(36, 41, 32, 0.06);
}

.state-error {
  background: linear-gradient(155deg, #FFFFFF, #F5E1D4);
}

.state-art {
  position: relative;
  width: 112rpx;
  height: 100rpx;
  margin: 0 auto 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: rgba(238, 243, 234, 0.76);
}

.state-icon {
  width: 58rpx;
  height: 58rpx;
}

.loading-art .state-icon {
  animation: state-breathe 1.4s ease-in-out infinite;
}

.state-title {
  color: #242920;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.45;
}

.state-description {
  margin-top: 10rpx;
  color: #596057;
  font-size: 24rpx;
  line-height: 1.65;
}

.retry-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin-top: 24rpx;
  color: #FFFFFF;
  background: #2E452C;
  border-radius: 24rpx;
  font-weight: 800;
}

@keyframes state-breathe {
  0%, 100% { transform: translateY(5rpx) scale(0.92); opacity: 0.62; }
  50% { transform: translateY(-5rpx) scale(1); opacity: 1; }
}
