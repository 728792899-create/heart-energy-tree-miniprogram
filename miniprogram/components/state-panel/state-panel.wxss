.state-panel {
  width: 100%;
  padding: 44rpx 30rpx;
  border: 1rpx solid rgba(183, 68, 101, 0.14);
  border-radius: 30rpx;
  text-align: center;
  background: linear-gradient(155deg, #fffdf9, #f8e6ec);
}

.state-error {
  background: linear-gradient(155deg, #fff9f5, #fcebec);
}

.state-art {
  position: relative;
  width: 120rpx;
  height: 100rpx;
  margin: 0 auto 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
}

.envelope {
  font-size: 62rpx;
}

.heart {
  position: absolute;
  color: #e77c99;
  font-size: 26rpx;
  animation: heart-rise 1.4s ease-in-out infinite;
}

.heart-one {
  left: 15rpx;
  top: 22rpx;
}

.heart-two {
  right: 12rpx;
  top: 5rpx;
  animation-delay: -0.7s;
}

.state-title {
  color: #7d2f49;
  font-size: 29rpx;
  font-weight: 850;
  line-height: 1.45;
}

.state-description {
  margin-top: 10rpx;
  color: #7b6970;
  font-size: 23rpx;
  line-height: 1.65;
}

.retry-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin-top: 24rpx;
  color: #fff;
  background: #b74465;
  border-radius: 28rpx;
  font-weight: 800;
}

@keyframes heart-rise {
  0%, 100% { transform: translateY(8rpx) scale(0.86); opacity: 0.45; }
  50% { transform: translateY(-8rpx) scale(1.05); opacity: 1; }
}
