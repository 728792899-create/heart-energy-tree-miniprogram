.dialog-backdrop {
  position: fixed;
  z-index: 1000;
  inset: 0;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(69, 52, 58, 0.48);
}

.dialog-sheet {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  padding: 42rpx 30rpx 30rpx;
  border: 1rpx solid rgba(135, 97, 77, 0.42);
  border-radius: 34rpx;
  text-align: center;
  background: #FFFDF7;
  box-shadow: 0 30rpx 76rpx rgba(69, 52, 58, 0.22);
}

.dialog-seal {
  position: absolute;
  top: -34rpx;
  left: 50%;
  width: 68rpx;
  height: 68rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid #f5d6df;
  border-radius: 50%;
  color: #fff;
  background: #3F6548;
  font-size: 34rpx;
  font-weight: 900;
}

.dialog-title {
  color: #3F6548;
  font-size: 33rpx;
  font-weight: 900;
}

.dialog-message {
  margin-top: 14rpx;
  color: #6c585f;
  font-size: 24rpx;
  line-height: 1.65;
}

.dialog-actions {
  margin-top: 26rpx;
  display: grid;
  gap: 14rpx;
}

.dialog-actions.two {
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
}

.cancel-button,
.confirm-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 26rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.cancel-button {
  color: #3F6548;
  background: #E7EFE4;
}

.confirm-button {
  color: #fff;
  background: #3F6548;
}

.confirm-button.dangerous {
  background: #a53b42;
}
