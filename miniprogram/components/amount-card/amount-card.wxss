.amount-card {
  position: relative;
  overflow: hidden;
  min-height: 170rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(63, 101, 72, 0.14);
  background: linear-gradient(145deg, #FFFDF7, #E7EFE4);
}

.amount-card::after {
  content: "♥";
  position: absolute;
  right: 18rpx;
  top: 8rpx;
  color: rgba(63, 101, 72, 0.09);
  font-size: 84rpx;
}

.amount-label {
  color: #7C837A;
  font-size: 22rpx;
}

.amount-row {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.amount-value {
  color: #3F6548;
  font-size: 46rpx;
  font-weight: 900;
}

.amount-unit {
  color: #3F6548;
  font-size: 20rpx;
  font-weight: 700;
}

.amount-caption {
  margin-top: 6rpx;
  color: #7C837A;
  font-size: 20rpx;
}

.tone-gold {
  background: linear-gradient(145deg, #FFFDF7, #fff1d9);
  border-color: rgba(135, 97, 77, 0.28);
}

.tone-gold .amount-value {
  color: #9d7330;
}
