.motion-scene {
  position: relative;
  overflow: hidden;
  width: 100%;
  aspect-ratio: 1 / 1;
  border: 1rpx solid #E8E1D3;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #FFFFFF, #E7EFE4);
}

.motion-video,
.motion-poster,
.native-fallback {
  width: 100%;
  height: 100%;
}

.native-fallback {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 50% 46%, #FFFFFF 0, #EEF3EA 68%, #F4ECD1 100%);
  animation: fallback-in 520ms cubic-bezier(.18,.8,.2,1) both;
}

.native-tree-image {
  width: 66%;
  height: 66%;
  animation: tree-grow 560ms cubic-bezier(.18,.8,.2,1) both;
}

.native-gift-image {
  width: 58%;
  height: 48%;
  border: 1rpx solid rgba(46, 69, 44, 0.14);
  border-radius: 28rpx;
  box-shadow: 0 22rpx 44rpx rgba(36, 41, 32, 0.12);
  animation: gift-pop 560ms cubic-bezier(.18,.8,.2,1) both;
}

.native-particle {
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  animation: particle-burst 520ms cubic-bezier(.18,.8,.2,1) both;
}

.heart-a,
.coin-a { left: 22%; top: 28%; }

.heart-b,
.coin-b { right: 20%; top: 22%; animation-delay: 80ms; }

.heart-c,
.coin-c { right: 27%; bottom: 21%; animation-delay: 140ms; }

.is-compact {
  max-height: 330rpx;
}

.is-reduced-motion .native-fallback,
.is-reduced-motion .native-tree-image,
.is-reduced-motion .native-gift-image,
.is-reduced-motion .native-particle {
  animation: none;
  transform: none;
}

@keyframes tree-grow {
  from { opacity: 0; transform: translateY(30rpx) scale(0.72); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes particle-burst {
  from { opacity: 0; transform: translateY(20rpx) scale(0.4) rotate(-12deg); }
  to { opacity: 1; transform: translateY(-14rpx) scale(1) rotate(8deg); }
}

@keyframes fallback-in {
  from { opacity: 0; transform: scale(0.94); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes gift-pop {
  from { opacity: 0; transform: translateY(30rpx) scale(0.68) rotate(-4deg); }
  to { opacity: 1; transform: translateY(0) scale(1) rotate(0); }
}
