<view wx:if="{{visible}}" class="motion-scene {{compact ? 'is-compact' : ''}} {{reducedMotion ? 'is-reduced-motion' : ''}}" role="img" aria-label="情侣庆祝动效">
  <video wx:if="{{!reducedMotion && resolvedSrc && !videoFailed}}" class="motion-video" src="{{resolvedSrc}}" autoplay="{{autoplay}}" loop="{{loop}}" muted="{{soundMode === 'off'}}" controls="{{false}}" show-center-play-btn="{{false}}" object-fit="cover" binderror="onVideoError" bindended="onEnded"></video>
  <image wx:elif="{{resolvedPoster && !posterFailed}}" class="motion-poster" src="{{resolvedPoster}}" mode="aspectFill" binderror="onPosterError"></image>
  <view wx:else class="native-fallback native-{{nativeVariant}} scene-{{sceneKey}}" bindanimationend="onNativeEnded">
    <block wx:if="{{nativeVariant === 'coins'}}">
      <image class="native-gift-image" src="/assets/stitch-original/redemption-gift.jpg" mode="aspectFill"></image>
      <image class="native-particle coin-a" src="/assets/generated/particle-petal.png" mode="aspectFit"></image>
      <image class="native-particle coin-b" src="/assets/generated/particle-heart.png" mode="aspectFit"></image>
      <image class="native-particle coin-c" src="/assets/generated/particle-star.png" mode="aspectFit"></image>
    </block>
    <block wx:elif="{{nativeVariant === 'ribbon'}}">
      <image class="native-tree-image" src="/assets/generated/tree-level-5.png" mode="aspectFit"></image>
      <image class="native-particle heart-a" src="/assets/generated/particle-petal.png" mode="aspectFit"></image>
      <image class="native-particle heart-b" src="/assets/generated/particle-heart.png" mode="aspectFit"></image>
    </block>
    <block wx:else>
      <image class="native-tree-image" src="/assets/generated/tree-level-5.png" mode="aspectFit"></image>
      <image class="native-particle heart-a" src="/assets/generated/particle-heart.png" mode="aspectFit"></image>
      <image class="native-particle heart-b" src="/assets/generated/particle-petal.png" mode="aspectFit"></image>
      <image class="native-particle heart-c" src="/assets/generated/particle-heart.png" mode="aspectFit"></image>
    </block>
  </view>
</view>
