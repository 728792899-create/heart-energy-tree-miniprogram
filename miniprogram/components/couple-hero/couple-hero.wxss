.couple-hero {
  position: relative;
  overflow: hidden;
  width: 100%;
  min-height: 300rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border: 1rpx solid #E8E1D3;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #FFFFFF 0%, #FBF6EB 58%, #E7EFE4 100%);
  box-shadow: 0 16rpx 38rpx rgba(36, 41, 32, 0.07);
}

.couple-hero::before {
  content: "";
  position: absolute;
  left: -60rpx;
  bottom: -78rpx;
  width: 210rpx;
  height: 210rpx;
  border: 2rpx solid rgba(154, 113, 91, 0.18);
  border-radius: 50%;
}

.hero-copy {
  position: relative;
  z-index: 2;
  flex: 1;
  min-width: 0;
}

.hero-eyebrow {
  display: inline-flex;
  min-height: 40rpx;
  align-items: center;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #3F6548;
  background: #EEF3EA;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 16rpx;
  color: #242920;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: #596057;
  font-size: 24rpx;
  line-height: 1.62;
}

.mascot-wrap {
  position: relative;
  z-index: 1;
  flex: 0 0 244rpx;
  width: 244rpx;
  min-height: 224rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.mascot-image {
  width: 244rpx;
  height: 188rpx;
  border: 1rpx solid rgba(46, 69, 44, 0.12);
  border-radius: 28rpx;
  background: #EEF3EA;
}

.mascot-caption {
  margin-top: 10rpx;
  color: #596057;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
}

.couple-hero.is-compact {
  min-height: 184rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  box-shadow: none;
}

.couple-hero.is-compact::before {
  display: none;
}

.is-compact .hero-eyebrow {
  min-height: 32rpx;
  padding: 0;
  background: transparent;
  color: #7C837A;
  font-size: 20rpx;
}

.is-compact .hero-title {
  margin-top: 6rpx;
  color: #2E452C;
  font-size: 34rpx;
  line-height: 1.18;
}

.is-compact .hero-subtitle {
  margin-top: 6rpx;
  color: #596057;
  font-size: 22rpx;
  line-height: 1.45;
}

.is-compact .mascot-wrap {
  flex-basis: 132rpx;
  width: 132rpx;
  min-height: 120rpx;
}

.is-compact .mascot-image {
  width: 132rpx;
  height: 104rpx;
  border-radius: 22rpx;
}

.is-compact .mascot-caption {
  display: none;
}

@media (max-width: 340px) {
  .couple-hero {
    align-items: flex-start;
  }

  .mascot-wrap {
    flex-basis: 186rpx;
    width: 186rpx;
  }

  .mascot-image {
    width: 186rpx;
  }

  .mascot-caption {
    display: none;
  }

  .is-compact .mascot-wrap {
    flex-basis: 104rpx;
    width: 104rpx;
  }

  .is-compact .mascot-image {
    width: 104rpx;
  }
}
