<view class="couple-hero {{compact ? 'is-compact' : ''}} role-{{role}}">
  <view class="hero-copy">
    <view class="hero-eyebrow">{{eyebrow}}</view>
    <view class="hero-title">{{title}}</view>
    <view class="hero-subtitle">{{subtitle}}</view>
    <slot></slot>
  </view>
  <view class="mascot-wrap" aria-label="两条相互陪伴的成长路径">
    <image class="mascot-image" src="{{mascotSrc}}" mode="aspectFill"></image>
    <view class="mascot-caption">双生路径 · 固定两人</view>
  </view>
</view>
