.encouragement-editor {
  overflow: hidden;
  padding: 28rpx;
  border: 1rpx solid rgba(183, 68, 101, 0.15);
  border-radius: 30rpx;
  background: linear-gradient(150deg, #fffdf9, #f8e6ec);
  box-shadow: 0 16rpx 38rpx rgba(125, 47, 73, 0.07);
}

.editor-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.editor-title {
  color: #7d2f49;
  font-size: 30rpx;
  font-weight: 900;
}

.editor-subtitle {
  margin-top: 8rpx;
  color: #7b6970;
  font-size: 22rpx;
  line-height: 1.55;
}

.letter-mark {
  font-size: 48rpx;
}

.template-scroll {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.template-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 18rpx;
}

.template-button {
  min-width: 126rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 24rpx;
  color: #7d2f49;
  background: #fff9f5;
  font-size: 23rpx;
  font-weight: 800;
}

.template-button.selected {
  color: #fff;
  background: #b74465;
  box-shadow: 0 10rpx 22rpx rgba(183, 68, 101, 0.2);
}

.message-input {
  width: 100%;
  min-height: 150rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(183, 68, 101, 0.16);
  border-radius: 24rpx;
  color: #45343a;
  background: #fff;
  line-height: 1.6;
}

.counter {
  margin-top: 6rpx;
  color: #927d84;
  text-align: right;
  font-size: 20rpx;
}

.send-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin-top: 18rpx;
  border-radius: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #b74465, #d45f7e);
  font-size: 26rpx;
  font-weight: 850;
}
