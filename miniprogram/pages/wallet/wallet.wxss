.wallet-page {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.wallet-balance-hero {
  position: relative;
  overflow: hidden;
  padding: 38rpx 32rpx 30rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.1);
  border-radius: 38rpx;
  background:
    radial-gradient(circle at 88% 10%, rgba(255, 198, 200, 0.42), transparent 34%),
    linear-gradient(145deg, #fffdfb 0%, #fff3f4 52%, #f8e5e9 100%);
  box-shadow: 0 20rpx 48rpx rgba(113, 30, 60, 0.1);
}

.wallet-hero-orb {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  display: flex;
  width: 96rpx;
  height: 96rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(143, 54, 83, 0.1);
  border-radius: 42% 58% 58% 42% / 52% 44% 56% 48%;
  background: rgba(255, 255, 255, 0.72);
  transform: rotate(8deg);
}

.wallet-hero-heart {
  color: #ff807c;
  font-size: 58rpx;
  font-weight: 900;
  transform: rotate(-8deg);
}

.wallet-hero-eyebrow {
  display: block;
  color: #7d2f49;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 5rpx;
}

.wallet-hero-title {
  margin-top: 9rpx;
  color: #5d1731;
  font-size: 42rpx;
  font-weight: 900;
}

.wallet-available-label {
  margin-top: 38rpx;
  color: #8d747c;
  font-size: 23rpx;
}

.wallet-available-value {
  display: flex;
  align-items: baseline;
  margin-top: 4rpx;
  color: #711e3c;
  font-size: 68rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.wallet-currency {
  margin-right: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.wallet-hero-caption {
  max-width: 520rpx;
  margin-top: 10rpx;
  color: #806870;
  font-size: 23rpx;
  line-height: 1.6;
}

.wallet-balance-secondary {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.wallet-balance-mini {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(113, 30, 60, 0.08);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.68);
}

.wallet-balance-paid {
  background: rgba(241, 246, 237, 0.82);
}

.wallet-mini-icon {
  display: flex;
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: #9e651e;
  background: #fff0c9;
  font-size: 26rpx;
  font-weight: 900;
}

.wallet-balance-paid .wallet-mini-icon {
  color: #466c50;
  background: #dfeee2;
}

.wallet-mini-label {
  overflow: hidden;
  color: #927780;
  font-size: 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.wallet-mini-value {
  margin-top: 3rpx;
  color: #5d3645;
  font-size: 28rpx;
  font-weight: 900;
}

.wallet-section-heading,
.wallet-record-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  margin: 36rpx 6rpx 18rpx;
}

.wallet-section-title {
  color: #4d2433;
  font-size: 31rpx;
  font-weight: 900;
}

.wallet-section-subtitle {
  margin-top: 6rpx;
  color: #71565f;
  font-size: 21rpx;
  line-height: 1.5;
}

.wallet-section-mark {
  color: #d47892;
  font-size: 46rpx;
  font-weight: 900;
}

.withdrawal-request-card {
  padding: 28rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.11);
  border-radius: 30rpx;
  background: rgba(255, 253, 250, 0.96);
  box-shadow: 0 14rpx 34rpx rgba(89, 45, 59, 0.08);
}

.withdrawal-field-label {
  color: #5c3442;
  font-size: 24rpx;
  font-weight: 800;
}

.withdrawal-amount-field {
  display: flex;
  align-items: center;
  margin-top: 13rpx;
  padding: 8rpx 20rpx;
  border: 2rpx solid rgba(143, 54, 83, 0.16);
  border-radius: 22rpx;
  background: #fff9f8;
}

.withdrawal-yuan-symbol {
  color: #8f3653;
  font-size: 31rpx;
  font-weight: 900;
}

.withdrawal-amount-input {
  min-width: 0;
  height: 82rpx;
  flex: 1;
  margin: 0 12rpx;
  color: #5d1731;
  font-size: 38rpx;
  font-weight: 900;
}

.withdrawal-field-unit {
  color: #71565f;
  font-size: 22rpx;
}

.withdrawal-note-label {
  margin-top: 26rpx;
}

.withdrawal-note-input {
  min-height: 132rpx;
  margin-top: 13rpx;
  border-color: rgba(143, 54, 83, 0.13);
  background: #fff9f8;
}

.withdrawal-submit-button {
  margin-top: 24rpx;
}

.withdrawal-safety-note {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 18rpx;
  color: #71565f;
  font-size: 21rpx;
  line-height: 1.55;
}

.withdrawal-safety-icon {
  display: flex;
  width: 30rpx;
  height: 30rpx;
  flex: 0 0 30rpx;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
  border-radius: 50%;
  color: #fff;
  background: #b8768b;
  font-size: 20rpx;
  font-weight: 900;
}

.wallet-record-count {
  flex: 0 0 auto;
  padding: 8rpx 17rpx;
  border-radius: 999rpx;
  color: #7d2947;
  background: #f3dfe5;
  font-size: 21rpx;
  font-weight: 800;
}

.withdrawal-record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.withdrawal-record-card {
  position: relative;
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr);
  gap: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.1);
  border-radius: 26rpx;
  background: rgba(255, 253, 250, 0.96);
  box-shadow: 0 10rpx 26rpx rgba(89, 45, 59, 0.07);
}

.withdrawal-record-icon {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #9c415f;
  background: #f9e7ec;
  font-size: 38rpx;
  font-weight: 900;
}

.withdrawal-record-main {
  min-width: 0;
}

.withdrawal-record-topline {
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.withdrawal-record-amount {
  color: #92394f;
  font-size: 34rpx;
  font-weight: 900;
}

.withdrawal-status-badge {
  flex: 0 0 auto;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.status-active {
  color: #7a2443;
  background: #f8dce5;
}

.status-warning {
  color: #8d5712;
  background: #fff0c9;
}

.status-success {
  color: #3e674e;
  background: #dfeee2;
}

.status-muted {
  color: #766d70;
  background: #eee8e9;
}

.withdrawal-record-note {
  overflow: hidden;
  margin-top: 9rpx;
  color: #665159;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.withdrawal-record-date {
  margin-top: 8rpx;
  color: #a18c92;
  font-size: 20rpx;
}

.withdrawal-result-note {
  grid-column: 1 / -1;
  padding: 15rpx 18rpx;
  border-left: 6rpx solid #d9a0b0;
  border-radius: 10rpx 16rpx 16rpx 10rpx;
  color: #755d66;
  background: #f9e9ed;
  font-size: 22rpx;
  line-height: 1.55;
}

.wallet-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 34rpx;
  border: 2rpx dashed rgba(143, 54, 83, 0.12);
  border-radius: 28rpx;
  text-align: center;
  background: rgba(255, 253, 250, 0.72);
}

.wallet-empty-icon {
  color: #cf8298;
  font-size: 58rpx;
  font-weight: 900;
}

.wallet-empty-title {
  margin-top: 10rpx;
  color: #5d3645;
  font-size: 28rpx;
  font-weight: 900;
}

.wallet-empty-description {
  margin-top: 8rpx;
  color: #99838a;
  font-size: 22rpx;
  line-height: 1.55;
}

@media (max-width: 360px) {
  .wallet-balance-hero {
    padding-right: 24rpx;
    padding-left: 24rpx;
  }

  .wallet-hero-orb {
    right: 16rpx;
    transform: scale(0.82) rotate(8deg);
  }

  .wallet-balance-secondary {
    grid-template-columns: minmax(0, 1fr);
  }

  .withdrawal-record-card {
    grid-template-columns: 64rpx minmax(0, 1fr);
    gap: 14rpx;
    padding: 20rpx;
  }

  .withdrawal-record-icon {
    width: 64rpx;
    height: 64rpx;
  }

  .withdrawal-record-topline {
    align-items: flex-start;
    flex-direction: column;
    gap: 8rpx;
  }
}
