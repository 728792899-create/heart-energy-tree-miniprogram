.companion-ledger-page { min-height: 100vh; background: #FFFDF7; }
.companion-ledger-header { display: flex; align-items: center; justify-content: space-between; gap: 24rpx; padding: 8rpx 4rpx 24rpx; }
.companion-ledger-header > view:first-child { min-width: 0; flex: 1 1 auto; }
.companion-ledger-kicker { color: #2E452C; font-size: 20rpx; font-weight: 900; letter-spacing: .15em; }
.companion-ledger-title { margin-top: 8rpx; color: #242920; font-size: 40rpx; font-weight: 900; }
.companion-ledger-copy { margin-top: 10rpx; color: #7C837A; font-size: 22rpx; line-height: 1.55; }
.companion-ledger-avatar { overflow: hidden; box-sizing: border-box; display: flex; align-items: center; justify-content: center; flex: 0 0 74rpx; width: 74rpx; height: 74rpx; border-radius: 50%; color: #fff; background: #2E452C; font-size: 26rpx; font-weight: 900; box-shadow: 0 9rpx 24rpx rgba(46, 69, 44,.16); }
.companion-ledger-balance-card { position: relative; overflow: hidden; padding: 38rpx 34rpx; border-radius: 36rpx; color: #fff; background: linear-gradient(145deg,#2E452C,#704A39); box-shadow: 0 18rpx 48rpx rgba(46, 69, 44,.18); text-align: center; }
.companion-ledger-balance-seal { position: absolute; right: 20rpx; top: 2rpx; color: rgba(255,255,255,.12); font-size: 150rpx; line-height: 1; }
.companion-ledger-balance-label { position: relative; font-size: 22rpx; font-weight: 750; }
.companion-ledger-balance-value { position: relative; margin-top: 10rpx; font-size: 58rpx; font-weight: 900; }
.companion-ledger-balance-value text { margin-right: 6rpx; font-size: 31rpx; }
.companion-ledger-balance-caption { position: relative; max-width: 520rpx; margin: 15rpx auto 0; color: rgba(255,255,255,.78); font-size: 20rpx; line-height: 1.55; }
.companion-ledger-summary-grid { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 14rpx; margin-top: 20rpx; }
.companion-ledger-summary-card { min-width: 0; padding: 24rpx 14rpx; border: 1rpx solid rgba(232, 225, 211,.74); border-radius: 26rpx; background: #fff; text-align: center; }
.companion-ledger-summary-card.is-income { background: #f3f9f1; }
.companion-ledger-summary-card.is-expense { background: #EEF3EA; }
.companion-ledger-summary-card.is-net { background: #fff8ed; }
.companion-ledger-summary-label,.companion-ledger-summary-count { color: #7C837A; font-size: 20rpx; }
.companion-ledger-summary-value { overflow: hidden; margin-top: 8rpx; color: #242920; font-size: 27rpx; font-weight: 900; text-overflow: ellipsis; white-space: nowrap; }
.companion-ledger-summary-count { margin-top: 7rpx; }
.companion-ledger-section-heading { display: flex; align-items: flex-end; justify-content: space-between; gap: 18rpx; margin: 38rpx 4rpx 20rpx; }
.companion-ledger-section-title { margin-top: 7rpx; color: #242920; font-size: 31rpx; font-weight: 900; }
.companion-ledger-section-count { color: #7C837A; font-size: 20rpx; }
.companion-ledger-timeline { display: grid; }
.companion-ledger-entry { position: relative; padding: 0 0 20rpx 54rpx; }
.companion-ledger-line { position: absolute; left: 19rpx; top: 30rpx; bottom: -6rpx; width: 2rpx; background: #E8E1D3; }
.companion-ledger-entry:last-child .companion-ledger-line { display: none; }
.companion-ledger-dot { position: absolute; left: 8rpx; top: 27rpx; width: 24rpx; height: 24rpx; border: 7rpx solid #FFFDF7; border-radius: 50%; background: #3F6548; box-shadow: 0 0 0 2rpx #b0cfaa; }
.companion-ledger-entry.is-expense .companion-ledger-dot { background: #2E452C; box-shadow: 0 0 0 2rpx #ffb1c4; }
.companion-ledger-entry-card { padding: 25rpx; border: 1rpx solid rgba(232, 225, 211,.74); border-radius: 28rpx; background: #fff; }
.companion-ledger-entry-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.companion-ledger-entry-head > view:first-child { min-width: 0; flex: 1 1 auto; }
.companion-ledger-entry-type { color: #242920; font-size: 27rpx; font-weight: 900; }
.companion-ledger-entry-date { margin-top: 6rpx; color: #7C837A; font-size: 20rpx; }
.companion-ledger-entry-amount { flex: 0 0 auto; color: #3F6548; font-size: 28rpx; font-weight: 900; }
.companion-ledger-entry.is-expense .companion-ledger-entry-amount { color: #2E452C; }
.companion-ledger-entry-note { margin-top: 18rpx; color: #596057; font-size: 22rpx; line-height: 1.55; }
.companion-ledger-entry-meta { display: flex; justify-content: space-between; gap: 18rpx; margin-top: 17rpx; padding-top: 15rpx; border-top: 1rpx solid #f0e3e5; color: #7C837A; font-size: 20rpx; }
.companion-ledger-empty-state { padding: 60rpx 36rpx; border: 1rpx dashed #E8E1D3; border-radius: 34rpx; background: #fff; text-align: center; }
.companion-ledger-empty-icon { display: flex; align-items: center; justify-content: center; width: 74rpx; height: 74rpx; margin: 0 auto; border-radius: 50%; color: #7d4c00; background: #F4ECD1; font-size: 30rpx; font-weight: 900; }
.companion-ledger-empty-title { margin-top: 22rpx; color: #242920; font-size: 29rpx; font-weight: 900; }
.companion-ledger-empty-copy { max-width: 520rpx; margin: 13rpx auto 0; color: #7C837A; font-size: 22rpx; line-height: 1.65; }
@media (max-width: 360px) {
  .companion-ledger-summary-grid { grid-template-columns: minmax(0,1fr); }
  .companion-ledger-summary-card { display: grid; grid-template-columns: minmax(0,1fr) auto; align-items: center; gap: 4rpx 16rpx; text-align: left; }
  .companion-ledger-summary-value { grid-row: 1 / span 2; grid-column: 2; }
  .companion-ledger-entry-head,.companion-ledger-entry-meta { align-items: flex-start; flex-direction: column; }
}
