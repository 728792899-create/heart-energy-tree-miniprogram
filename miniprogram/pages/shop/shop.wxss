.shop-page {
  padding-top: 18rpx;
}

.shop-topbar,
.shop-brand {
  display: flex;
  align-items: center;
}

.shop-topbar {
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.shop-brand {
  gap: 14rpx;
}

.shop-avatar {
  width: 62rpx;
  height: 62rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
}

.shop-eyebrow {
  color: #544246;
  font-size: 19rpx;
}

.shop-title {
  color: #711E3C;
  font-size: 30rpx;
  font-weight: 850;
}

.shop-record-link {
  width: auto;
  min-height: 64rpx;
  padding: 0 20rpx;
  color: #8F3653;
  background: #FFF0F2;
  font-size: 22rpx;
  font-weight: 800;
}

.shop-balance-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 26rpx;
  padding: 34rpx 28rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.52);
  border-radius: 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #FFF0F2 0%, #FBEAEC 54%, #FFFFFF 100%);
  box-shadow: 0 14rpx 36rpx rgba(113, 30, 60, 0.08);
}

.balance-glow {
  position: absolute;
  top: -70rpx;
  right: -40rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.58);
}

.balance-label,
.balance-hint,
.balance-value {
  position: relative;
  z-index: 1;
}

.balance-label {
  color: #544246;
  font-size: 22rpx;
}

.balance-value {
  margin: 8rpx 0;
  color: #8F3653;
  font-size: 58rpx;
  font-weight: 900;
}

.balance-value::before {
  content: "◉";
  margin-right: 10rpx;
  color: #D4AE6A;
  font-size: 36rpx;
}

.balance-hint {
  color: #877276;
  font-size: 20rpx;
}

.tabs {
  width: 100%;
  margin-bottom: 22rpx;
  white-space: nowrap;
}

.tab-row {
  display: flex;
  gap: 12rpx;
  padding: 3rpx 2rpx 8rpx;
}

.tab {
  min-width: 118rpx;
  min-height: 64rpx;
  padding: 0 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.62);
  border-radius: 999rpx;
  color: #544246;
  background: #FFFFFF;
  font-size: 22rpx;
  font-weight: 750;
}

.tab-icon {
  color: #8F3653;
  font-size: 18rpx;
}

.tab.active {
  color: #FFFFFF;
  border-color: #8F3653;
  background: #8F3653;
}

.tab.active .tab-icon {
  color: #FFFFFF;
}

.shop-section-title {
  margin: 8rpx 0 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #22191B;
  font-size: 29rpx;
  font-weight: 850;
}

.shop-section-icon {
  color: #8F3653;
}

.shop-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
}

.reward-card {
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(217, 192, 197, 0.56);
  border-radius: 22rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(113, 30, 60, 0.06);
}

.reward-image,
.reward-img {
  width: 100%;
  height: 190rpx;
}

.reward-image {
  overflow: hidden;
}

.reward-body {
  flex: 1;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
}

.reward-name {
  color: #22191B;
  font-size: 27rpx;
  font-weight: 850;
}

.reward-description {
  overflow: hidden;
  min-height: 66rpx;
  margin-top: 7rpx;
  color: #544246;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 20rpx;
  line-height: 1.55;
}

.reward-price {
  margin: 12rpx 0;
  color: #8F3653;
  font-size: 23rpx;
  font-weight: 800;
}

.reward-action {
  width: 100%;
  min-height: 70rpx;
  margin-top: auto;
  color: #FFFFFF;
  background: #8F3653;
  font-size: 22rpx;
  font-weight: 800;
}

.long-wish-card {
  position: relative;
  overflow: hidden;
  margin-top: 28rpx;
  min-height: 190rpx;
  display: grid;
  grid-template-columns: 180rpx minmax(0, 1fr) 48rpx;
  align-items: center;
  border: 1rpx solid rgba(217, 192, 197, 0.58);
  border-radius: 24rpx;
  background: #FFFFFF;
}

.long-wish-image {
  width: 180rpx;
  height: 190rpx;
}

.long-wish-copy {
  padding: 20rpx;
}

.long-wish-kicker {
  color: #8F3653;
  font-size: 20rpx;
  font-weight: 750;
}

.long-wish-title {
  margin: 7rpx 0;
  color: #711E3C;
  font-size: 27rpx;
  font-weight: 850;
}

.long-wish-arrow {
  color: #8F3653;
  font-size: 48rpx;
}

@media (max-width: 340px) {
  .shop-topbar {
    align-items: flex-start;
    flex-direction: column;
  }

  .shop-grid,
  .long-wish-card {
    grid-template-columns: minmax(0, 1fr);
  }

  .long-wish-image {
    width: 100%;
    height: 240rpx;
  }

  .long-wish-arrow {
    display: none;
  }
}
