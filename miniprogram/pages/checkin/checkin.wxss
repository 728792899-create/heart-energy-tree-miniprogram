.checkin-page {
  padding-top: 20rpx;
}

.checkin-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.checkin-title {
  margin-top: 6rpx;
  color: #2E452C;
  font-size: 38rpx;
  font-weight: 850;
}

.checkin-avatar {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(46, 69, 44, 0.12);
}

.current-card {
  margin-bottom: 24rpx;
  border-color: rgba(232, 225, 211, 0.72);
}

.card-title {
  color: #2E452C;
  font-size: 30rpx;
  font-weight: 800;
}

.preview {
  width: 100%;
  height: 360rpx;
  margin-top: 22rpx;
  border-radius: 20rpx;
}

.review-note,
.pending-reward {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
}

.review-note {
  color: #2E452C;
  background: #F0F6EE;
  line-height: 1.6;
}

.pending-reward {
  text-align: center;
  background: #EEF3EA;
}

.pending-plus {
  color: #2E452C;
  font-size: 42rpx;
  font-weight: 850;
}

.submit-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.checkin-bento {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
}

.bento-card {
  min-height: 210rpx;
  padding: 26rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(232, 225, 211, 0.42);
  border-radius: 28rpx;
  text-align: center;
}

.duration-card {
  color: #2E452C;
  background: #E7EFE4;
}

.type-card {
  color: #2E452C;
  background: #FFFFFF;
}

.bento-icon {
  margin-bottom: 8rpx;
  font-size: 42rpx;
  line-height: 1;
}

.bento-label {
  color: #596057;
  font-size: 22rpx;
}

.duration-entry {
  margin-top: 8rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 5rpx;
  font-size: 22rpx;
}

.duration-input {
  width: 86rpx;
  height: 62rpx;
  color: #2E452C;
  font-size: 46rpx;
  font-weight: 850;
  text-align: right;
}

.type-name {
  margin-top: 12rpx;
  color: #2E452C;
  font-size: 30rpx;
  font-weight: 850;
}

.upload-section {
  padding: 20rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
}

.upload-label {
  margin: 0 4rpx 14rpx;
  color: #596057;
  font-size: 22rpx;
  font-weight: 700;
}

.photo-picker {
  position: relative;
  overflow: hidden;
  width: 100%;
  min-height: 420rpx;
  padding: 0;
  border: 2rpx dashed #E8E1D3;
  border-radius: 22rpx;
  color: #2E452C;
  background: #FFFDF7;
}

.photo-empty,
.photo-empty-asset,
.photo-preview {
  width: 100%;
  height: 420rpx;
}

.photo-empty {
  position: relative;
}

.photo-empty-asset {
  display: block;
  opacity: 0.5;
}

.photo-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(255, 248, 248, 0.45);
}

.photo-empty-copy {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 86%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.camera-mark {
  width: 82rpx;
  height: 82rpx;
  margin: 0 auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #FFFFFF;
  background: #2E452C;
  font-size: 46rpx;
}

.photo-title {
  color: #2E452C;
  font-size: 28rpx;
  font-weight: 800;
}

.photo-hint {
  margin-top: 8rpx;
  color: #596057;
  font-size: 21rpx;
}

.photo-change {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  min-height: 52rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: rgba(34, 25, 27, 0.72);
  font-size: 22rpx;
}

.mood-panel {
  padding: 24rpx;
  border-radius: 28rpx;
  background: #E7EFE4;
}

.mood-title {
  margin-bottom: 16rpx;
  color: #2E452C;
  font-size: 24rpx;
  font-weight: 800;
}

.mood-strip,
.quick-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.mood-option {
  min-height: 116rpx;
  padding: 12rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 20rpx;
  color: #2E452C;
  background: rgba(255, 255, 255, 0.58);
  font-size: 22rpx;
}

.mood-option.active {
  color: #FFFFFF;
  background: #2E452C;
  box-shadow: 0 8rpx 22rpx rgba(43, 68, 41, 0.18);
}

.mood-icon {
  font-size: 34rpx;
}

.quick-chip {
  min-height: 72rpx;
  color: #2E452C;
  background: #EEF3EA;
  font-size: 23rpx;
  font-weight: 800;
}

.label-row {
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.label {
  color: #242920;
  font-weight: 800;
}

.soft-textarea {
  min-height: 168rpx;
  background: #FFFFFF;
}

.promise-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.7);
  border-radius: 22rpx;
  background: #FFFFFF;
}

.promise-dot {
  flex: 0 0 26rpx;
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: #9A715B;
  box-shadow: 0 0 0 9rpx rgba(255, 137, 126, 0.14);
}

.promise-title {
  margin-bottom: 5rpx;
  color: #2E452C;
  font-size: 26rpx;
  font-weight: 800;
}

.submit-btn {
  width: 100%;
  min-height: 94rpx;
  color: #FFFFFF;
  background: #9A715B;
  box-shadow: 0 14rpx 30rpx rgba(255, 137, 126, 0.25);
  font-size: 28rpx;
  font-weight: 850;
}

.done-empty {
  background: #FFFFFF;
}

@media (max-width: 360px) {
  .checkin-bento,
  .mood-strip,
  .quick-row {
    grid-template-columns: minmax(0, 1fr);
  }

  .bento-card {
    min-height: 160rpx;
  }
}
