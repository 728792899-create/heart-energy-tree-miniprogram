.rewards-admin-page {
  background: #FFFDF7;
}

.admin-rewards-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 18rpx 0 24rpx;
}

.admin-rewards-title {
  margin: 10rpx 0 8rpx;
  color: #242920;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.admin-rules-link {
  flex: 0 0 auto;
  min-height: 64rpx;
  padding: 0 20rpx;
  color: #3F6548;
  background: transparent;
  font-size: 24rpx;
}

.reward-library-summary {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 24rpx;
  align-items: center;
  margin-bottom: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(63, 101, 72, 0.1);
  border-radius: 34rpx;
  background: linear-gradient(145deg, #FFFDF7, #F6F1E7);
  box-shadow: 0 16rpx 42rpx rgba(63, 101, 72, 0.08);
}

.section-kicker {
  color: #3F6548;
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.reward-summary-title {
  margin: 8rpx 0;
  color: #242920;
  font-size: 32rpx;
  font-weight: 900;
}

.reward-summary-stats {
  display: flex;
  gap: 12rpx;
}

.reward-summary-stat {
  min-width: 96rpx;
  padding: 18rpx 12rpx;
  text-align: center;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.8);
}

.reward-summary-value {
  color: #3F6548;
  font-size: 31rpx;
  font-weight: 900;
}

.reward-summary-label {
  margin-top: 4rpx;
  color: #79696e;
  font-size: 20rpx;
}

.reward-editor-sheet {
  margin-bottom: 30rpx;
  padding: 28rpx;
  border-radius: 36rpx;
  background: #FFFDF7;
}

.reward-editor-handle {
  width: 72rpx;
  height: 8rpx;
  margin: -8rpx auto 20rpx;
  border-radius: 999rpx;
  background: #e4cfd5;
}

.reward-editor-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.reward-editor-title {
  margin-top: 6rpx;
  color: #242920;
  font-size: 31rpx;
  font-weight: 900;
}

.reward-editor-close {
  flex: 0 0 64rpx;
  width: 64rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 50%;
  color: #3F6548;
  background: #f7e8ec;
  font-size: 38rpx;
}

.reward-image-picker {
  overflow: hidden;
  width: 100%;
  height: 250rpx;
  padding: 0;
  border: 2rpx dashed #DCE8D5;
  border-radius: 28rpx;
  background: #E7EFE4;
}

.reward-preview,
.reward-image-empty,
.reward-image-empty-asset {
  width: 100%;
  height: 250rpx;
}

.reward-image-empty {
  position: relative;
  overflow: hidden;
}

.reward-image-empty-asset {
  opacity: 0.42;
}

.reward-image-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 250, 247, 0.34);
}

.reward-image-plus {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: #3F6548;
  font-size: 40rpx;
  font-weight: 900;
}

.reward-image-label {
  margin-top: 10rpx;
  color: #596057;
  font-size: 23rpx;
  font-weight: 900;
}

.reward-form-field {
  margin-top: 20rpx;
}

.reward-form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #242920;
  font-weight: 800;
}

.reward-picker-field {
  min-height: 82rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #f0dce2;
  border-radius: 18rpx;
  color: #242920;
  background: #ffffff;
}

.reward-form-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.reward-list-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.reward-list-title {
  margin: 6rpx 0 0;
}

.reward-admin-list {
  display: grid;
  gap: 18rpx;
  padding-bottom: 110rpx;
}

.reward-admin-card {
  padding: 22rpx;
  border-color: rgba(63, 101, 72, 0.1);
  background: #FFFDF7;
}

.reward-admin-main {
  display: flex;
  gap: 18rpx;
}

.reward-admin-media {
  flex: 0 0 150rpx;
  width: 150rpx;
  height: 150rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #E7EFE4;
}

.reward-admin-thumb {
  width: 100%;
  height: 100%;
}

.reward-admin-info {
  flex: 1;
  min-width: 0;
}

.reward-admin-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.reward-admin-name {
  color: #242920;
  font-size: 29rpx;
  font-weight: 900;
}

.reward-admin-price {
  margin-top: 6rpx;
  color: #a06b16;
  font-size: 22rpx;
  font-weight: 900;
}

.reward-admin-meta {
  margin-top: 10rpx;
  color: #596057;
  font-size: 21rpx;
}

.reward-admin-description {
  margin-top: 8rpx;
  color: #654f56;
  font-size: 23rpx;
  line-height: 1.5;
}

.reward-status-switch {
  position: relative;
  flex: 0 0 68rpx;
  width: 68rpx;
  min-height: 38rpx;
  height: 38rpx;
  padding: 0;
  border-radius: 999rpx;
}

.reward-status-active {
  background: #3F6548;
}

.reward-status-muted {
  background: #e4dde0;
}

.reward-switch-knob {
  position: absolute;
  top: 5rpx;
  left: 5rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ffffff;
  transition: transform 160ms ease;
}

.reward-status-active .reward-switch-knob {
  transform: translateX(30rpx);
}

.reward-admin-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(63, 101, 72, 0.08);
}

.reward-edit-action,
.reward-delete-action {
  min-height: 60rpx;
  padding: 0 14rpx;
  background: transparent;
  font-size: 22rpx;
}

.reward-edit-action {
  color: #596057;
}

.reward-delete-action {
  color: #704A39;
}

.reward-empty-state {
  padding: 58rpx 30rpx;
  text-align: center;
  border: 2rpx dashed #DCE8D5;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.72);
}

.reward-empty-icon {
  width: 82rpx;
  height: 82rpx;
  margin: 0 auto 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  color: #ffffff;
  background: #3F6548;
  font-size: 46rpx;
  font-weight: 900;
}

.reward-empty-title {
  color: #242920;
  font-size: 31rpx;
  font-weight: 900;
}

.reward-empty-action {
  width: 72%;
  margin: 24rpx auto 0;
}

.reward-floating-add {
  position: fixed;
  z-index: 8;
  right: 32rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  width: 88rpx;
  min-height: 88rpx;
  padding: 0;
  border-radius: 28rpx;
  color: #ffffff;
  background: #3F6548;
  font-size: 48rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 32rpx rgba(63, 101, 72, 0.28);
}

@media (max-width: 360px) {
  .reward-library-summary,
  .reward-form-grid,
  .reward-form-actions,
  .reward-admin-actions {
    grid-template-columns: minmax(0, 1fr);
  }

  .reward-summary-stats {
    width: 100%;
  }

  .reward-summary-stat {
    flex: 1;
  }

  .reward-admin-main {
    flex-direction: column;
  }

  .reward-admin-media {
    width: 100%;
    height: 220rpx;
  }

  .reward-list-heading {
    align-items: flex-start;
  }
}
