.payout-page {
  background: #fffaf7;
}

.payout-inbox-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 18rpx 0 24rpx;
}

.payout-page-title {
  margin: 10rpx 0 8rpx;
  color: #45343a;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.payout-header-count {
  flex: 0 0 82rpx;
  width: 82rpx;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: #7d2f49;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 28rpx rgba(125, 47, 73, 0.2);
}

.payout-hero-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 22rpx;
  padding: 36rpx 30rpx 32rpx;
  text-align: center;
  border: 1rpx solid rgba(125, 47, 73, 0.1);
  border-radius: 40rpx;
  background: linear-gradient(145deg, #fffdfb, #f9e6ea);
  box-shadow: 0 18rpx 50rpx rgba(125, 47, 73, 0.1);
}

.payout-hero-card::after {
  content: "♡";
  position: absolute;
  right: -12rpx;
  bottom: -54rpx;
  color: rgba(125, 47, 73, 0.06);
  font-size: 210rpx;
  line-height: 1;
}

.payout-heart-seal {
  position: relative;
  z-index: 1;
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 42rpx 42rpx 48rpx 34rpx;
  color: #a23c5e;
  background: rgba(255, 255, 255, 0.84);
  font-size: 74rpx;
  font-weight: 400;
  transform: rotate(-4deg);
  box-shadow: 0 12rpx 30rpx rgba(125, 47, 73, 0.08);
}

.payout-hero-kicker,
.section-kicker {
  color: #a23c5e;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.payout-hero-title {
  margin: 10rpx 0;
  color: #3f3035;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.3;
}

.payout-hero-description {
  position: relative;
  z-index: 1;
  max-width: 560rpx;
  margin: 0 auto;
  color: #79696e;
  font-size: 25rpx;
  line-height: 1.65;
}

.payout-hero-amount {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  color: #8f3653;
  font-size: 54rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.payout-hero-currency {
  margin-right: 4rpx;
  font-size: 30rpx;
}

.payout-hero-caption {
  position: relative;
  z-index: 1;
  margin-top: 4rpx;
  color: #8a777e;
  font-size: 21rpx;
}

.payout-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.payout-summary-item {
  min-width: 0;
  padding: 20rpx 10rpx;
  text-align: center;
  border: 1rpx solid rgba(125, 47, 73, 0.1);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
}

.payout-summary-value {
  color: #7d2f49;
  font-size: 34rpx;
  font-weight: 900;
}

.payout-summary-label {
  margin-top: 4rpx;
  color: #79696e;
  font-size: 21rpx;
}

.payout-section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.payout-section-title {
  margin: 6rpx 0 0;
}

.payout-safety-note {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #557258;
  background: #edf4ed;
  font-size: 20rpx;
  font-weight: 800;
}

.payout-task-list {
  display: grid;
  gap: 24rpx;
}

.payout-task-card {
  padding: 28rpx;
  border-color: rgba(125, 47, 73, 0.12);
  background: #fffdfb;
}

.payout-task-active {
  border-left: 8rpx solid #a63d36;
}

.payout-task-warning {
  border-left: 8rpx solid #d09a43;
}

.payout-task-success,
.payout-task-muted {
  border-left: 8rpx solid #79917b;
}

.payout-task-heading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.payout-task-icon {
  flex: 0 0 62rpx;
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #ffffff;
  background: #7d2f49;
  font-size: 27rpx;
  font-weight: 900;
}

.payout-task-copy {
  flex: 1;
  min-width: 0;
}

.payout-task-name {
  color: #45343a;
  font-size: 30rpx;
  font-weight: 900;
}

.payout-status-badge {
  flex: 0 0 auto;
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.payout-status-active {
  color: #7d2f49;
  background: #f7dfe6;
}

.payout-status-warning {
  color: #805f22;
  background: #f8edcf;
}

.payout-status-success {
  color: #315f37;
  background: #e3f0e3;
}

.payout-status-muted {
  color: #6f6568;
  background: #eee9ea;
}

.payout-request-context {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 22rpx;
  align-items: end;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: #fbf0f2;
}

.payout-context-label {
  color: #8a777e;
  font-size: 21rpx;
  font-weight: 800;
}

.payout-request-note {
  margin-top: 8rpx;
  color: #543f46;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.5;
}

.payout-amount-block {
  max-width: 240rpx;
  text-align: right;
}

.payout-amount {
  color: #9f403c;
  font-size: 39rpx;
  font-weight: 900;
  white-space: nowrap;
}

.payout-action-panel {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(125, 47, 73, 0.12);
}

.payout-transfer-panel {
  padding: 22rpx;
  border: 1rpx solid rgba(208, 154, 67, 0.2);
  border-radius: 26rpx;
  background: #fffaf0;
}

.payout-action-title {
  margin-bottom: 6rpx;
  color: #45343a;
  font-size: 29rpx;
  font-weight: 900;
}

.payout-field {
  margin-top: 20rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #5b474d;
  font-weight: 800;
}

.compact-textarea {
  min-height: 126rpx;
}

.payout-decision-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.payout-approve-button,
.payout-paid-button {
  background: #a63d36;
}

.payout-reject-button {
  color: #6d3b45;
  background: #f5e6e9;
}

.payout-paid-button {
  width: 100%;
  margin-top: 18rpx;
}

.payout-complete-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f0f5f0;
}

.payout-complete-mark {
  flex: 0 0 54rpx;
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: #557258;
  font-size: 26rpx;
  font-weight: 900;
}

.payout-complete-title {
  color: #405743;
  font-size: 27rpx;
  font-weight: 900;
}

.payout-empty-state {
  padding: 54rpx 30rpx;
  text-align: center;
  border: 2rpx dashed #e4bec9;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.68);
}

.payout-empty-icon {
  color: #a23c5e;
  font-size: 70rpx;
}

.payout-empty-title {
  margin: 10rpx 0 8rpx;
  color: #45343a;
  font-size: 31rpx;
  font-weight: 900;
}

@media (max-width: 360px) {
  .payout-inbox-header,
  .payout-section-heading,
  .payout-task-heading {
    align-items: flex-start;
  }

  .payout-summary-grid,
  .payout-request-context,
  .payout-decision-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .payout-amount-block {
    max-width: none;
    text-align: left;
  }

  .payout-status-badge,
  .payout-safety-note {
    white-space: normal;
    text-align: center;
  }
}
