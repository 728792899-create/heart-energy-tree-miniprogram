<view class="page profile-page">
  <state-panel wx:if="{{loading}}" state="loading" title="正在翻开我们的情侣护照…" description="头像、成就和成长记录正在整理。"></state-panel>
  <state-panel wx:elif="{{errorMessage}}" state="error" title="情侣护照暂时打不开" description="{{errorMessage}}" bindretry="retryLoad"></state-panel>
  <block wx:else>
  <view class="band profile-head soft-hero">
    <view class="profile-cover">
      <view class="profile-cover-copy">
        <view class="profile-cover-kicker">LOVE GARDEN</view>
        <view class="profile-cover-title">把每一天，都种成我们的纪念</view>
      </view>
      <image class="profile-cover-image" src="/assets/stitch-original/profile-cover.jpg" mode="aspectFill"></image>
      <view class="profile-couple-avatar" role="button" aria-label="编辑头像和昵称" bindtap="goProfileEdit">
        <image wx:if="{{dashboard.currentUser.avatarSrc}}" src="{{dashboard.currentUser.avatarSrc}}" mode="aspectFill"></image>
        <view wx:else class="profile-couple-avatar-text">{{dashboard.currentUser.avatarText || '我'}}</view>
        <view class="profile-heart">双生</view>
      </view>
    </view>
    <view class="row-between head-inner">
      <view>
        <text class="eyebrow">{{currentRoleText}}</text>
        <view class="profile-title"><text class="profile-title-name">{{dashboard.currentUser.name}}</text><text class="profile-title-heart">与</text><text class="profile-title-name">{{companionName}}</text></view>
        <view class="muted small">{{dashboard.currentRole === 'participant' ? '今天也被认真守护着' : '你在守护这棵能量树'}}</view>
      </view>
    </view>
    <button class="secondary-btn edit-btn" aria-label="编辑头像和昵称" bindtap="goProfileEdit">编辑头像和昵称</button>
    <view wx:if="{{!isCloudMode}}" class="role-switch">
      <button class="role-btn {{dashboard.currentRole === 'participant' ? 'active' : ''}}" data-role="participant" aria-label="切换到女友端视角" bindtap="onSwitchRole">女友端</button>
      <button class="role-btn {{dashboard.currentRole === 'sponsor' ? 'active' : ''}}" data-role="sponsor" aria-label="切换到男友端视角" bindtap="onSwitchRole">男友端</button>
    </view>
  </view>

  <view class="card passport-setting">
    <view class="setting-copy">
      <view class="card-title">心动提示音</view>
      <view class="muted small">只在绑定、里程碑、约定兑现等关键时刻轻轻响起。</view>
    </view>
    <switch checked="{{isSoundEnabled}}" color="#2E452C" aria-label="开启或关闭心动提示音" bindchange="onSoundToggle"></switch>
  </view>

  <view class="card passport-setting">
    <view class="setting-copy">
      <view class="card-title">简化动效</view>
      <view class="muted small">保留静态心动海报，减少循环、弹跳和爆发动画。</view>
    </view>
    <switch checked="{{reducedMotion}}" color="#2E452C" aria-label="开启或关闭简化动效" bindchange="onReducedMotionToggle"></switch>
  </view>

  <block wx:if="{{dashboard.currentRole === 'participant'}}">
    <view class="section-title">佩戴中的成就</view>
    <view wx:if="{{dashboard.relationship.equippedBadges.length}}" class="equipped-row">
      <view wx:for="{{dashboard.relationship.equippedBadges}}" wx:key="id" class="equipped-badge">
        <view class="equipped-icon">{{item.iconText}}</view>
        <view class="equipped-name">{{item.name}}</view>
      </view>
    </view>
    <view wx:else class="empty">从已解锁成就里点选 3 个，就会展示在这里。</view>

    <view class="profile-bento-stats grid-2 stat-grid">
      <view class="card stat-card">
        <view class="stat-number">{{dashboard.relationship.stats.currentStreak}}</view>
        <view class="muted small">当前连续</view>
      </view>
      <view class="card stat-card">
        <view class="stat-number">{{dashboard.relationship.stats.totalDurationMinutes}}</view>
        <view class="muted small">累计分钟</view>
      </view>
      <view class="card stat-card">
        <view class="stat-number">{{dashboard.relationship.stats.badgeCount}}</view>
        <view class="muted small">已解锁成就</view>
      </view>
      <view class="card stat-card">
        <view class="stat-number">{{dashboard.relationship.stats.totalRedemptions}}</view>
        <view class="muted small">兑换次数</view>
      </view>
    </view>

    <view class="section-title">这个月的打卡</view>
    <view class="calendar">
      <view wx:for="{{dayCells}}" wx:key="day" class="day {{item.status}}">
        <text>{{item.day}}</text>
      </view>
    </view>

    <view class="section-title">成就墙</view>
    <view class="badge-grid">
      <view wx:for="{{badges}}" wx:key="id" data-id="{{item.id}}" role="button" aria-label="{{item.unlocked ? (item.equipped ? '取消佩戴成就' + item.name : '佩戴成就' + item.name) : '未解锁成就' + item.name}}" bindtap="toggleBadge" class="badge {{item.unlocked ? 'unlocked' : 'locked'}} {{item.equipped ? 'equipped' : ''}}">
        <view class="badge-icon">
          <image wx:if="{{item.iconSrc}}" class="badge-image" src="{{item.iconSrc}}" mode="aspectFit"></image>
          <text wx:else>{{item.iconText}}</text>
        </view>
        <view class="badge-name">{{item.name}}</view>
        <view class="muted small">{{item.unlocked ? item.story : item.description}}</view>
        <view wx:if="{{item.equipped}}" class="equip-pill">佩戴</view>
      </view>
    </view>

    <view class="section-title">常用入口</view>
    <view class="grid-2">
      <button class="secondary-btn" aria-label="进入心愿金领取" bindtap="goWallet">心愿金领取</button>
      <button class="ghost-btn" aria-label="查看我的打卡历史" bindtap="goHistory">打卡历史</button>
      <button class="ghost-btn" aria-label="查看我的兑换记录" bindtap="goRedemptions">兑换记录</button>
      <button class="ghost-btn" aria-label="设置资料被查看提醒" bindtap="enableViewNoticeSubscription">被查看提醒</button>
    </view>
  </block>

  <block wx:else>
    <view class="card companion-card">
      <view class="row-between">
        <view>
          <view class="companion-title">她的守护面板</view>
          <view class="muted small">查看 {{companionName}} 的进度、成就和账本。</view>
        </view>
        <view class="companion-avatar">
          <image wx:if="{{dashboard.companionUser.avatarSrc}}" class="avatar-img" src="{{dashboard.companionUser.avatarSrc}}" mode="aspectFill"></image>
          <text wx:else>{{dashboard.companionUser.avatarText}}</text>
        </view>
      </view>
    </view>

    <view class="section-title">女友信息</view>
    <view class="grid-2">
      <button class="secondary-btn" aria-label="查看女友打卡历史" bindtap="goCompanionHistory">打卡历史</button>
      <button class="secondary-btn" aria-label="查看女友成就" bindtap="goCompanionBadges">她的成就</button>
      <button class="ghost-btn" aria-label="查看女友能量币记录" bindtap="goCompanionLedgers">能量币记录</button>
      <button class="ghost-btn" aria-label="查看女友兑换记录" bindtap="goCompanionRedemptions">兑换记录</button>
    </view>

    <view class="section-title">男友管理</view>
    <view class="grid-2">
      <button class="primary-btn" aria-label="进入打卡审核台，待处理{{dashboard.pendingCount}}条" bindtap="goReview">审核台 {{dashboard.pendingCount}}</button>
      <button class="secondary-btn" aria-label="进入心愿金处理，待处理{{dashboard.waitingPayoutCount}}条" bindtap="goPayouts">心愿金处理 {{dashboard.waitingPayoutCount}}</button>
      <button class="ghost-btn" aria-label="进入奖品管理" bindtap="goAdminRewards">奖品管理</button>
      <button class="ghost-btn" aria-label="进入奖励规则设置" bindtap="goRules">奖励规则</button>
    </view>

    <view wx:if="{{showInvitePartner}}">
      <view class="section-title">邀请另一半</view>
      <view class="card invite-card">
        <view>
          <view class="invite-title">把这棵能量树分享给 TA</view>
          <view class="muted small">TA 从你的分享卡片进入后，会自动进入绑定流程，不需要手动输入邀请码。</view>
        </view>
        <button class="primary-btn invite-btn" open-type="share" aria-label="分享情侣绑定邀请卡片">分享邀请卡片</button>
        <button class="ghost-btn invite-btn" aria-label="复制测试用情侣邀请路径" bindtap="copyInvitePath">复制测试邀请路径</button>
      </view>
    </view>
  </block>

  <view class="section-title relationship-settings-title">关系与隐私</view>
  <view class="card relationship-settings-card">
    <view class="relationship-settings-heading">
      <view>
        <view class="card-title">解除双人关系</view>
        <view class="muted small">必须由双方分别完成两次确认；解除不会自动删除历史数据。</view>
      </view>
      <view class="relationship-safety-badge">双方确认</view>
    </view>

    <view wx:if="{{dashboard.relationship.unbindStatus.state === 'waiting_for_partner' || (dashboard.relationship.unbindStatus.state === 'finalizing' && dashboard.relationship.unbindStatus.requestedByMe)}}" class="relationship-unbind-status is-waiting">
      <view class="relationship-unbind-status-title">{{dashboard.relationship.unbindStatus.state === 'finalizing' ? '双方已确认，正在安全收尾' : '已等待对方确认'}}</view>
      <view class="small">{{dashboard.relationship.unbindStatus.state === 'finalizing' ? '旧关系访问正在撤销。请保持网络连接；若失败，由另一方重新打开本页重试。' : '对方确认前，当前关系和正常功能不会改变。你可以随时撤回申请。'}}</view>
      <button
        wx:if="{{dashboard.relationship.unbindStatus.canCancel}}"
        class="relationship-action-btn is-neutral"
        loading="{{unbindSubmitting}}"
        disabled="{{unbindSubmitting}}"
        aria-label="撤回解除关系申请"
        bindtap="cancelRelationshipUnbind"
      >{{unbindSubmitting ? '正在处理…' : '撤回解除申请'}}</button>
    </view>

    <view wx:elif="{{dashboard.relationship.unbindStatus.state === 'action_required' || dashboard.relationship.unbindStatus.state === 'finalizing'}}" class="relationship-unbind-status is-required">
      <view class="relationship-unbind-status-title">{{dashboard.relationship.unbindStatus.state === 'finalizing' ? '解除收尾需要重试' : '对方申请解除关系'}}</view>
      <view class="small">{{dashboard.relationship.unbindStatus.state === 'finalizing' ? '双方确认已经记录，但旧信笺访问尚未完全撤销。请重新确认以继续安全收尾，不会重复冻结或删除数据。' : '只有你再次完成两次警告确认，解除才会生效；不操作不会自动解除。'}}</view>
      <button
        class="relationship-action-btn is-danger"
        loading="{{unbindSubmitting}}"
        disabled="{{unbindSubmitting}}"
        aria-label="确认解除关系"
        bindtap="confirmRelationshipUnbind"
      >{{unbindSubmitting ? '正在处理…' : '查看警告并确认'}}</button>
    </view>

    <view wx:else class="relationship-unbind-intro">
      <view class="small">发起后需等待另一方确认。生效后双方绑定、旧邀请与实时访问会失效，账本、信笺和照片按隐私说明冻结保留。</view>
      <button
        class="relationship-action-btn is-danger-outline"
        loading="{{unbindSubmitting}}"
        disabled="{{unbindSubmitting}}"
        aria-label="发起解除关系申请"
        bindtap="requestRelationshipUnbind"
      >{{unbindSubmitting ? '正在处理…' : '申请解除关系'}}</button>
    </view>
  </view>
  </block>
</view>
