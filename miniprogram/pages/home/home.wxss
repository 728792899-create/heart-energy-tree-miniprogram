.hero-band {
  padding-top: 34rpx;
}

.hero-inner {
  position: relative;
  z-index: 1;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #2f5f77;
  background: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.home-title {
  margin: 18rpx 0 8rpx;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 800;
}

.avatar {
  flex: 0 0 86rpx;
  width: 86rpx;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #B74465;
  background: #ffffff;
  font-weight: 800;
  overflow: hidden;
  box-shadow: 0 16rpx 36rpx rgba(184, 82, 112, 0.16);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.role-switch {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 10rpx;
  margin-top: 26rpx;
  padding: 8rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.6);
}

.role-btn {
  min-height: 68rpx;
  color: #5f6f66;
  background: transparent;
  font-size: 26rpx;
}

.role-btn.active {
  color: #B74465;
  background: #ffffff;
}

.tree-zone {
  overflow: hidden;
  margin-bottom: 26rpx;
  background: #fffafd;
  border: 1rpx solid #f2d9e1;
  border-radius: 8rpx;
  box-shadow: 0 16rpx 34rpx rgba(184, 82, 112, 0.08);
}

.tree-sky {
  position: relative;
  height: 360rpx;
  background: linear-gradient(180deg, #e8f7ff 0%, #FFF9F5 100%);
}

.sun {
  position: absolute;
  top: 28rpx;
  right: 26rpx;
  min-width: 128rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #B74465;
  background: #fff2bf;
  font-size: 24rpx;
  font-weight: 700;
}

.tree {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 330rpx;
  height: 330rpx;
  --tree-scale: 1;
  transform: translateX(-50%) scale(var(--tree-scale));
  animation: tree-breathe 3.4s ease-in-out infinite;
}

.tree-asset {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 20rpx 26rpx rgba(184, 82, 112, 0.12));
}

.tree-level-1 {
  --tree-scale: 0.64;
}

.tree-level-2 {
  --tree-scale: 0.74;
}

.tree-level-3 {
  --tree-scale: 0.84;
}

.tree-level-4 {
  --tree-scale: 0.94;
}

.tree-level-5 {
  --tree-scale: 1.02;
}

.couple-home-asset {
  position: absolute;
  right: 18rpx;
  bottom: 8rpx;
  width: 168rpx;
  height: 168rpx;
  opacity: 0.95;
  animation: float-card 3.2s ease-in-out infinite;
}

.tree-info {
  padding: 24rpx;
}

.tree-name {
  font-size: 34rpx;
  font-weight: 800;
}

.progress {
  overflow: hidden;
  height: 16rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: #F8E6EC;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #E77C99, #ffd166);
}

.progress-bar.blue {
  background: #7db9d8;
}

.adventure-preview {
  margin-bottom: 8rpx;
}

.map-chip {
  flex: 0 0 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: #7db9d8;
  font-size: 24rpx;
  font-weight: 800;
}

.wish-fund {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  color: #45554b;
  background: #F8E6EC;
  font-size: 24rpx;
}

.wish-progress {
  overflow: hidden;
  height: 12rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #F8E6EC;
}

.wish-progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #E77C99;
}

.actions {
  margin-bottom: 28rpx;
}

.check-date,
.card-title {
  font-weight: 800;
  font-size: 30rpx;
}

.card-message {
  margin-top: 12rpx;
  color: #45554b;
  line-height: 1.6;
}

.surprise {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #765117;
  background: #fff2bf;
  font-size: 24rpx;
  font-weight: 700;
}

.petal {
  position: absolute;
  width: 22rpx;
  height: 18rpx;
  border-radius: 70% 30% 70% 30%;
  background: #ffb3c7;
  opacity: 0.78;
  animation: petal-fall 4.4s linear infinite;
}

.petal-a {
  left: 130rpx;
  top: 40rpx;
}

.petal-b {
  right: 170rpx;
  top: 18rpx;
  animation-delay: -2.2s;
}

.sponsor-home-card {
  margin-bottom: 24rpx;
}

.sponsor-tree-line {
  margin-top: 24rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border-radius: 8rpx;
  background: #F8E6EC;
}

.small-money {
  flex: 0 0 auto;
  font-size: 34rpx;
}

.full-btn {
  width: 100%;
  margin-top: 22rpx;
}

.sponsor-count {
  flex: 0 0 82rpx;
  width: 82rpx;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: #E77C99;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 26rpx rgba(240, 140, 167, 0.24);
}

.stat-grid {
  margin-bottom: 26rpx;
}

.stat-card {
  text-align: center;
}

.stat-number {
  color: #B74465;
  font-size: 42rpx;
  font-weight: 900;
}

.home-state-card {
  padding: 52rpx 28rpx;
  text-align: center;
}

.home-heart-loader {
  margin-bottom: 18rpx;
  color: #e77c99;
  font-size: 56rpx;
  animation: heart-beat 1.1s ease-in-out infinite;
}

.home-retry {
  margin-top: 24rpx;
}

.love-letter-list,
.milestone-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.love-letter-card,
.milestone-card,
.weekly-preview {
  position: relative;
  overflow: hidden;
}

.love-letter-card {
  padding-right: 76rpx;
  background: linear-gradient(145deg, #fffdfb, #f8e6ec);
}

.letter-seal {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff9f5;
  background: #b74465;
  box-shadow: 0 8rpx 18rpx rgba(183, 68, 101, 0.2);
}

.receive-hug-button,
.milestone-button,
.custom-note-button {
  width: 100%;
  margin-top: 20rpx;
}

.weekly-preview {
  min-height: 156rpx;
  padding-right: 100rpx;
  border-color: rgba(212, 174, 106, 0.52);
  background: linear-gradient(150deg, #fffdf9, #f8e6ec);
}

.weekly-stamp {
  position: absolute;
  right: 18rpx;
  top: 22rpx;
  width: 64rpx;
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
  border: 2rpx dashed #d4ae6a;
  color: #7d2f49;
  font-size: 16rpx;
  font-weight: 900;
  text-align: center;
  transform: rotate(5deg);
}

.weekly-summary {
  margin-top: 16rpx;
  color: #7d2f49;
  font-size: 23rpx;
  font-weight: 700;
}

.milestone-card {
  border-color: rgba(212, 174, 106, 0.5);
}

.milestone-ribbon {
  display: inline-flex;
  margin-bottom: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #6b5128;
  background: #f6e8c9;
  font-size: 21rpx;
}

.quick-encouragement-card {
  background: linear-gradient(145deg, #fffdfb, #f8e6ec);
}

.quick-encouragement-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.quick-encouragement-button {
  min-width: 0;
  min-height: 88rpx;
  padding: 10rpx 12rpx;
  color: #7d2f49;
  background: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
}

.quick-icon {
  margin-right: 8rpx;
  color: #b74465;
}

@keyframes heart-beat {
  0%, 100% { transform: scale(1); }
  45% { transform: scale(1.14); }
}

@keyframes tree-breathe {
  0%, 100% {
    transform: translateX(-50%) scale(var(--tree-scale));
  }
  50% {
    transform: translateX(-50%) scale(calc(var(--tree-scale) * 1.035));
  }
}

@keyframes petal-fall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 0;
  }
  15% {
    opacity: 0.8;
  }
  100% {
    transform: translateY(250rpx) translateX(60rpx) rotate(210deg);
    opacity: 0;
  }
}

/* Stitch「晨曦陪伴花园」原版首页映射 */
.partner-note {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 18rpx 0 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #FFF0F2;
}

.partner-note-avatar {
  flex: 0 0 58rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 14rpx;
}

.partner-note-copy {
  flex: 1;
  min-width: 0;
}

.partner-note-name {
  color: #877276;
  font-size: 20rpx;
}

.partner-note-message {
  overflow: hidden;
  margin-top: 3rpx;
  color: #22191B;
  font-size: 23rpx;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.partner-note-time {
  align-self: flex-start;
  color: #877276;
  font-size: 18rpx;
}

.role-switch {
  width: 250rpx;
  margin-top: 12rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: #FFF0F2;
}

.role-btn {
  min-height: 48rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  color: #877276;
  font-size: 20rpx;
}

.role-btn.active {
  color: #FFFFFF;
  background: #8F3653;
}

.garden-hero {
  position: relative;
  overflow: hidden;
  height: 360rpx;
  margin-bottom: 24rpx;
  border-radius: 26rpx;
  background: #FBEAEC;
  box-shadow: 0 14rpx 38rpx rgba(84, 66, 70, 0.08);
}

.garden-hero-image {
  width: 100%;
  height: 100%;
}

.garden-hero-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, transparent 58%, rgba(34, 25, 27, 0.34));
}

.garden-level {
  position: absolute;
  left: 20rpx;
  bottom: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: rgba(65, 92, 62, 0.82);
  font-size: 20rpx;
  font-weight: 700;
}

.home-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.home-stat-card {
  position: relative;
  overflow: hidden;
  min-height: 174rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.3);
  border-radius: 22rpx;
  background: #FFFFFF;
  text-align: center;
}

.home-stat-card::after {
  content: "";
  position: absolute;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  opacity: 0.45;
}

.home-stat-motion::after {
  right: -42rpx;
  top: -38rpx;
  background: #FFD9E0;
}

.home-stat-streak::after {
  left: -38rpx;
  bottom: -44rpx;
  background: #CCEBC5;
}

.home-stat-icon {
  width: 50rpx;
  height: 50rpx;
  margin: 0 auto 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #711E3C;
  background: #FFD9E0;
  font-size: 26rpx;
}

.home-stat-streak .home-stat-icon {
  color: #2B4429;
  background: #CCEBC5;
}

.home-stat-value {
  color: #22191B;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.1;
}

.home-stat-value text {
  margin-left: 5rpx;
  color: #544246;
  font-size: 19rpx;
  font-weight: 500;
}

.home-stat-label {
  margin-top: 7rpx;
  color: #544246;
  font-size: 20rpx;
}

.stitch-primary-action {
  width: 100%;
  min-height: 94rpx;
  color: #76211C;
  border-radius: 24rpx;
  background: #FF897E;
  box-shadow: 0 14rpx 26rpx rgba(255, 137, 126, 0.22);
  font-size: 28rpx;
}

.home-quick-links {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin: 18rpx 0 4rpx;
}

.home-link {
  min-height: 68rpx;
  padding: 0 8rpx;
  border-radius: 18rpx;
  color: #711E3C;
  background: #FFF0F2;
  font-size: 21rpx;
  font-weight: 600;
}

.home-wish-fund {
  margin: 22rpx 0 8rpx;
  color: #544246;
  background: #FBEAEC;
}

.companion-stage {
  overflow: hidden;
  margin-bottom: 24rpx;
  border-radius: 26rpx;
  background: #FFF0F2;
  text-align: center;
}

.companion-stage-image {
  width: 100%;
  height: 290rpx;
}

.companion-stage-copy {
  padding: 24rpx 24rpx 28rpx;
}

.companion-stage-title {
  color: #711E3C;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.companion-stage-subtitle {
  margin-top: 10rpx;
  color: #544246;
  font-size: 22rpx;
  line-height: 1.6;
}

@media (max-width: 340px) {
  .home-quick-links {
    grid-template-columns: minmax(0, 1fr);
  }

  .partner-note-message {
    white-space: normal;
  }
}

.view-notice-banner {
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  min-height: 112rpx;
  margin-bottom: 22rpx;
  padding: 20rpx 18rpx 20rpx 22rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.11);
  border-radius: 22rpx;
  background: #fff0f2;
  box-shadow: 0 10rpx 26rpx rgba(113, 30, 60, 0.06);
}

.view-notice-icon {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 58rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff;
  background: #b95f7b;
  font-size: 34rpx;
  line-height: 1;
}

.view-notice-content {
  min-width: 0;
  flex: 1;
}

.view-notice-title {
  color: #711e3c;
  font-size: 24rpx;
  font-weight: 700;
}

.view-notice-message,
.view-notice-extra {
  margin-top: 5rpx;
  color: #715e64;
  font-size: 21rpx;
  line-height: 1.45;
}

.view-notice-extra {
  color: #9b6577;
}

.view-notice-close {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  min-height: 58rpx;
  flex: 0 0 58rpx;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 50%;
  color: #8f6d78;
  background: rgba(255, 255, 255, 0.72);
  font-size: 34rpx;
  line-height: 1;
}

.view-notice-close::after {
  border: 0;
}
