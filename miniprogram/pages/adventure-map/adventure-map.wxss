.map-page {
  padding-top: 18rpx;
}

.map-topbar,
.map-couple-mark {
  display: flex;
  align-items: center;
}

.map-topbar {
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.map-couple-mark {
  gap: 14rpx;
}

.map-avatar {
  width: 60rpx;
  height: 60rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
}

.map-eyebrow {
  color: #596057;
  font-size: 20rpx;
}

.map-page-title {
  color: #2E452C;
  font-size: 28rpx;
  font-weight: 850;
}

.map-bell {
  color: #2E452C;
  font-size: 34rpx;
}

.map-summary {
  position: relative;
  margin-bottom: 22rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.5);
  border-radius: 26rpx;
  background: #FFFFFF;
}

.map-summary-copy {
  padding-right: 120rpx;
}

.map-summary-label,
.level-kicker,
.next-milestone-kicker {
  color: #2E452C;
  font-size: 20rpx;
  font-weight: 750;
}

.map-title {
  margin: 8rpx 0;
  color: #2E452C;
  font-size: 36rpx;
  font-weight: 850;
}

.map-description {
  color: #596057;
  font-size: 22rpx;
  line-height: 1.55;
}

.map-progress-ring {
  position: absolute;
  top: 28rpx;
  right: 26rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #E7EFE4;
  border-radius: 50%;
  color: #2E452C;
  font-size: 22rpx;
  font-weight: 850;
  background: #F7FBF5;
}

.map-progress {
  overflow: hidden;
  height: 12rpx;
  margin: 24rpx 0 12rpx;
  border-radius: 999rpx;
  background: #F6F1E7;
}

.map-progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #2E452C;
}

.map-scene {
  position: relative;
  overflow: hidden;
  width: 100%;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.56);
  border-radius: 30rpx;
  background: #F6F1E7;
}

.map-road {
  position: relative;
  overflow: hidden;
  width: 100%;
  min-height: 1040rpx;
  padding: 74rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 42rpx;
  box-sizing: border-box;
}

.map-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.42;
}

.route-line {
  position: absolute;
  z-index: 0;
  top: 90rpx;
  bottom: 90rpx;
  left: 50%;
  width: 5rpx;
  border-radius: 999rpx;
  background: repeating-linear-gradient(180deg, #E8E1D3 0 16rpx, transparent 16rpx 30rpx);
  transform: translateX(-50%);
}

.level-node {
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 180rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.level-node.side-right {
  flex-direction: row-reverse;
}

.node-dot {
  flex: 0 0 78rpx;
  width: 78rpx;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 7rpx solid #FFFFFF;
  border-radius: 50%;
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(34, 25, 27, 0.12);
  font-size: 26rpx;
  font-weight: 850;
}

.level-node.locked {
  opacity: 0.58;
}

.level-node.current .node-dot {
  box-shadow: 0 0 0 12rpx rgba(255, 137, 126, 0.18), 0 8rpx 20rpx rgba(34, 25, 27, 0.12);
}

.node-card {
  flex: 1;
  min-width: 0;
  padding: 22rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.72);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
}

.node-title {
  margin: 5rpx 0;
  color: #242920;
  font-size: 28rpx;
  font-weight: 850;
}

.reward {
  margin-top: 9rpx;
  color: #2E452C;
  font-weight: 750;
}

.map-checkin-btn {
  width: 100%;
  min-height: 68rpx;
  margin-top: 14rpx;
  color: #FFFFFF;
  background: #2E452C;
  font-size: 22rpx;
  font-weight: 800;
}

.next-milestone-card {
  overflow: hidden;
  margin-bottom: 26rpx;
  display: grid;
  grid-template-columns: 190rpx minmax(0, 1fr);
  border: 1rpx solid rgba(232, 225, 211, 0.6);
  border-radius: 24rpx;
  background: #EEF3EA;
}

.next-milestone-image {
  width: 190rpx;
  height: 190rpx;
}

.next-milestone-copy {
  padding: 24rpx 22rpx;
}

.next-milestone-title {
  margin: 8rpx 0;
  color: #2E452C;
  font-size: 27rpx;
  font-weight: 850;
}

.map-rules {
  background: #FFFFFF;
}

.rule-line {
  position: relative;
  margin: 12rpx 0;
  padding-left: 24rpx;
  color: #596057;
  line-height: 1.55;
}

.rule-line::before {
  content: "";
  position: absolute;
  top: 16rpx;
  left: 0;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #E7EFE4;
}

@media (max-width: 340px) {
  .map-summary-copy {
    padding-right: 0;
  }

  .map-progress-ring {
    position: static;
    margin-top: 18rpx;
  }

  .next-milestone-card {
    grid-template-columns: minmax(0, 1fr);
  }

  .next-milestone-image {
    width: 100%;
    height: 240rpx;
  }
}
