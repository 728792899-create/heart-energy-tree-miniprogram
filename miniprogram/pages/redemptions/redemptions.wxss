.redemption-library-page {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.redemption-library-header {
  position: relative;
  overflow: hidden;
  padding: 38rpx 32rpx 0;
  border: 1rpx solid rgba(63, 101, 72, 0.12);
  border-radius: 34rpx;
  background: linear-gradient(145deg, #FFFDF7 0%, #EEF3EA 60%, #f9e5ea 100%);
  box-shadow: 0 18rpx 44rpx rgba(46, 69, 44, 0.1);
}

.redemption-header-copy {
  position: relative;
  z-index: 2;
  width: 70%;
}

.redemption-eyebrow {
  display: block;
  color: #3F6548;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 5rpx;
}

.redemption-header-title {
  margin-top: 10rpx;
  color: #704A39;
  font-size: 46rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.redemption-header-description {
  margin-top: 12rpx;
  color: #785d66;
  font-size: 25rpx;
  line-height: 1.65;
}

.redemption-header-mark {
  position: absolute;
  top: 28rpx;
  right: 26rpx;
  width: 130rpx;
  height: 128rpx;
  transform: rotate(3deg);
}

.redemption-gift-box,
.redemption-gift-lid {
  position: absolute;
  left: 17rpx;
  width: 96rpx;
  border: 2rpx solid rgba(46, 69, 44, 0.18);
  background: linear-gradient(135deg, #f8c9c6 0%, #e99cac 100%);
  box-shadow: 0 12rpx 22rpx rgba(46, 69, 44, 0.14);
}

.redemption-gift-lid {
  top: 34rpx;
  z-index: 2;
  height: 24rpx;
  border-radius: 9rpx;
}

.redemption-gift-box {
  top: 54rpx;
  height: 64rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.redemption-gift-box::after,
.redemption-gift-lid::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 40rpx;
  width: 16rpx;
  content: '';
  background: #fff4e3;
}

.redemption-ribbon {
  position: absolute;
  top: 7rpx;
  z-index: 3;
  width: 43rpx;
  height: 34rpx;
  border: 8rpx solid #fff4e3;
  border-radius: 50%;
}

.redemption-ribbon-left {
  left: 22rpx;
  transform: rotate(27deg);
}

.redemption-ribbon-right {
  right: 22rpx;
  transform: rotate(-27deg);
}

.redemption-summary-strip {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 30rpx -32rpx 0;
  padding: 22rpx 18rpx 24rpx;
  border-top: 1rpx solid rgba(63, 101, 72, 0.1);
  background: rgba(255, 255, 255, 0.58);
}

.redemption-summary-item {
  display: flex;
  min-width: 150rpx;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.redemption-summary-number {
  color: #2E452C;
  font-size: 34rpx;
  font-weight: 900;
}

.redemption-summary-label {
  color: #8a7078;
  font-size: 21rpx;
}

.redemption-summary-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(46, 69, 44, 0.12);
}

.redemption-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 26rpx;
}

.redemption-voucher-card {
  overflow: hidden;
  padding: 22rpx;
  border: 1rpx solid rgba(46, 69, 44, 0.1);
  border-radius: 28rpx;
  background: rgba(255, 253, 250, 0.96);
  box-shadow: 0 12rpx 30rpx rgba(89, 45, 59, 0.08);
}

.redemption-voucher-main {
  display: flex;
  min-width: 0;
  align-items: stretch;
  gap: 22rpx;
}

.redemption-voucher-image {
  width: 176rpx;
  height: 158rpx;
  flex: 0 0 176rpx;
  border-radius: 20rpx;
  background: #E7EFE4;
}

.redemption-voucher-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
}

.redemption-voucher-topline {
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.redemption-category {
  overflow: hidden;
  color: #9a6f7d;
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.redemption-status-badge {
  flex: 0 0 auto;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.status-active {
  color: #7a2443;
  background: #F4ECD1;
}

.status-warning {
  color: #8d5712;
  background: #F4ECD1;
}

.status-success {
  color: #3e674e;
  background: #E7EFE4;
}

.status-muted {
  color: #766d70;
  background: #E8E1D3;
}

.redemption-title {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 15rpx;
  color: #4d2433;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.3;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.redemption-price-row {
  display: flex;
  align-items: center;
  margin-top: auto;
  padding-top: 12rpx;
}

.redemption-coin {
  color: #d59838;
  font-size: 23rpx;
  font-weight: 900;
}

.redemption-price {
  margin-left: 6rpx;
  color: #a16617;
  font-size: 24rpx;
  font-weight: 800;
}

.redemption-date {
  margin-left: auto;
  color: #a48d94;
  font-size: 20rpx;
}

.redemption-description {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  color: #755d66;
  background: #fff7f5;
  font-size: 24rpx;
  line-height: 1.6;
}

.redemption-action-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx dashed rgba(63, 101, 72, 0.24);
  border-radius: 22rpx;
  background: linear-gradient(145deg, #FFFDF7 0%, #EEF3EA 100%);
}

.redemption-action-heading {
  color: #65233c;
  font-size: 26rpx;
  font-weight: 900;
}

.redemption-action-hint {
  margin-top: 5rpx;
  color: #927780;
  font-size: 22rpx;
  line-height: 1.55;
}

.redemption-note {
  min-height: 112rpx;
  margin-top: 16rpx;
  border-color: rgba(63, 101, 72, 0.14);
  background: #fffefd;
}

.redemption-action-button {
  margin-top: 16rpx;
}

.redemption-action-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
}

.redemption-action-grid .redemption-action-button {
  width: 100%;
  min-width: 0;
  padding-right: 10rpx;
  padding-left: 10rpx;
}

.redemption-note-stack {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}

.redemption-history-note {
  padding: 14rpx 18rpx;
  border-left: 6rpx solid #dba4b3;
  border-radius: 10rpx 16rpx 16rpx 10rpx;
  color: #785d66;
  background: #F6F1E7;
  font-size: 22rpx;
  line-height: 1.55;
}

.redemption-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 26rpx;
  padding: 72rpx 40rpx 58rpx;
  border: 1rpx solid rgba(63, 101, 72, 0.1);
  border-radius: 30rpx;
  text-align: center;
  background: rgba(255, 253, 250, 0.94);
  box-shadow: 0 14rpx 34rpx rgba(89, 45, 59, 0.07);
}

.redemption-empty-gift {
  position: relative;
  width: 176rpx;
  height: 150rpx;
}

.redemption-empty-lid,
.redemption-empty-box {
  position: absolute;
  left: 18rpx;
  width: 140rpx;
  border: 2rpx solid rgba(46, 69, 44, 0.12);
  background: linear-gradient(135deg, #f4c1c5 0%, #e695a8 100%);
}

.redemption-empty-lid {
  top: 44rpx;
  z-index: 2;
  height: 28rpx;
  border-radius: 10rpx;
}

.redemption-empty-box {
  top: 68rpx;
  height: 76rpx;
  border-radius: 0 0 22rpx 22rpx;
}

.redemption-empty-lid::after,
.redemption-empty-box::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 58rpx;
  width: 24rpx;
  content: '';
  background: #fff3db;
}

.redemption-empty-bow {
  position: absolute;
  top: -4rpx;
  left: 61rpx;
  z-index: 3;
  color: #704A39;
  font-size: 72rpx;
  font-weight: 900;
}

.redemption-empty-title {
  margin-top: 18rpx;
  color: #704A39;
  font-size: 34rpx;
  font-weight: 900;
}

.redemption-empty-description {
  max-width: 520rpx;
  margin-top: 12rpx;
  color: #8a7078;
  font-size: 24rpx;
  line-height: 1.65;
}

.redemption-empty-button {
  width: 100%;
  margin-top: 28rpx;
}

@media (max-width: 360px) {
  .redemption-library-header {
    padding-right: 24rpx;
    padding-left: 24rpx;
  }

  .redemption-header-copy {
    width: 74%;
  }

  .redemption-header-mark {
    right: 10rpx;
    transform: scale(0.82) rotate(3deg);
  }

  .redemption-summary-strip {
    margin-right: -24rpx;
    margin-left: -24rpx;
  }

  .redemption-summary-item {
    min-width: 0;
  }

  .redemption-voucher-main {
    gap: 16rpx;
  }

  .redemption-voucher-image {
    width: 142rpx;
    height: 142rpx;
    flex-basis: 142rpx;
  }

  .redemption-date {
    display: none;
  }

  .redemption-action-grid {
    grid-template-columns: minmax(0, 1fr);
    gap: 0;
  }
}
