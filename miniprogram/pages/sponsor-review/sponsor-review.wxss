.review-page {
  background: #fffaf7;
}

.review-inbox-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 18rpx 0 24rpx;
}

.review-page-title {
  margin: 10rpx 0 8rpx;
  color: #45343a;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.review-header-count {
  flex: 0 0 82rpx;
  width: 82rpx;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: #7d2f49;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 28rpx rgba(125, 47, 73, 0.2);
}

.review-hero-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(125, 47, 73, 0.1);
  border-radius: 38rpx;
  background: linear-gradient(145deg, #fffdfb, #f9e6ea);
  box-shadow: 0 18rpx 50rpx rgba(125, 47, 73, 0.1);
}

.review-hero-image {
  width: 100%;
  height: 250rpx;
  border-radius: 28rpx;
}

.review-hero-copy {
  margin-top: 24rpx;
  text-align: center;
}

.review-hero-kicker,
.section-kicker {
  color: #a23c5e;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.review-hero-title {
  margin: 10rpx 0;
  color: #3f3035;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.3;
}

.review-hero-description {
  color: #79696e;
  font-size: 25rpx;
  line-height: 1.65;
}

.review-hero-action {
  width: 72%;
  margin: 24rpx auto 0;
  background: #a63d36;
}

.review-toolbar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.review-section-title {
  margin: 6rpx 0 0;
}

.review-balance {
  text-align: right;
}

.review-balance-value {
  margin-top: 4rpx;
  color: #557258;
  font-size: 32rpx;
  font-weight: 900;
}

.review-quick-links {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.review-queue-list {
  display: grid;
  gap: 24rpx;
}

.review-queue-card {
  padding: 28rpx;
  border-color: rgba(125, 47, 73, 0.12);
  background: #fffdfb;
}

.review-card-heading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.review-entry-number {
  flex: 0 0 62rpx;
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #ffffff;
  background: #557258;
  font-size: 28rpx;
  font-weight: 900;
}

.review-entry-copy {
  flex: 1;
  min-width: 0;
}

.review-date {
  color: #45343a;
  font-size: 31rpx;
  font-weight: 900;
}

.review-status-badge {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #315f37;
  font-size: 21rpx;
  font-weight: 800;
}

.review-evidence-panel {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: #fbf0f2;
}

.review-image {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  background: #eef2ef;
}

.photo-unavailable {
  min-height: 250rpx;
  padding: 34rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  text-align: center;
  border: 2rpx dashed #e4bec9;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #fff9f5, #f8e6ec);
}

.photo-unavailable-icon {
  color: #a23c5e;
  font-size: 58rpx;
}

.photo-unavailable-title {
  color: #7d2f49;
  font-size: 28rpx;
  font-weight: 900;
}

.review-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.review-meta-label {
  color: #71565f;
  font-size: 21rpx;
}

.review-meta-value {
  margin-top: 6rpx;
  color: #543f46;
  font-size: 26rpx;
  font-weight: 900;
}

.review-note {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  color: #5d4b51;
  background: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  font-style: italic;
  line-height: 1.55;
}

.review-decision-panel {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(125, 47, 73, 0.12);
}

.decision-heading {
  margin-bottom: 18rpx;
}

.decision-title {
  color: #45343a;
  font-size: 29rpx;
  font-weight: 900;
}

.decision-field + .decision-field {
  margin-top: 20rpx;
}

.label {
  margin-bottom: 10rpx;
  font-weight: 800;
}

.compact-textarea {
  min-height: 120rpx;
}

.reject-label {
  color: #7a3a35;
}

.review-decision-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.action-btn {
  width: 100%;
  min-width: 0;
}

.review-empty-state {
  padding: 52rpx 28rpx;
  text-align: center;
}

.review-empty-heart {
  color: #a23c5e;
  font-size: 64rpx;
}

.review-empty-title {
  margin: 8rpx 0;
  color: #45343a;
  font-size: 31rpx;
  font-weight: 900;
}

@media (max-width: 360px) {
  .review-inbox-header,
  .review-toolbar {
    align-items: flex-start;
  }

  .review-hero-action {
    width: 100%;
  }

  .review-quick-links,
  .review-meta-grid,
  .review-decision-actions {
    grid-template-columns: minmax(0, 1fr);
  }

  .review-card-heading {
    flex-wrap: wrap;
  }

  .review-status-badge {
    margin-left: 78rpx;
  }
}
