.edit-page {
  min-height: 100vh;
  padding: 0;
  background: linear-gradient(180deg, #FFF4F5 0%, #FFF9F7 100%);
}

.profile-edit-sheet {
  min-height: 100vh;
  padding: 36rpx 38rpx calc(54rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: transparent;
}

.profile-sheet-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-sheet-kicker {
  color: #7C837A;
  font-size: 21rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.profile-sheet-title {
  margin-top: 8rpx;
  color: #242920;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.profile-edit-close {
  flex: 0 0 72rpx;
  width: 72rpx;
  min-height: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 50%;
  color: #596057;
  background: #EEF3EA;
  font-size: 48rpx;
  font-weight: 400;
  line-height: 68rpx;
}

.profile-avatar-editor {
  display: flex;
  align-items: center;
  gap: 26rpx;
  margin-top: 34rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.46);
  border-radius: 30rpx;
  background: #FFFFFF;
}

.avatar-picker {
  position: relative;
  flex: 0 0 148rpx;
  width: 148rpx;
  min-height: 148rpx;
  height: 148rpx;
  padding: 0;
  overflow: visible;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #EEF3EA;
  border-radius: 50%;
  background: #E7EFE4;
  box-shadow: 0 14rpx 30rpx rgba(63, 101, 72, 0.1);
}

.avatar-img {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
}

.avatar-text {
  color: #2E452C;
  font-size: 48rpx;
  font-weight: 900;
}

.avatar-camera-mark {
  position: absolute;
  right: -6rpx;
  bottom: -6rpx;
  width: 52rpx;
  height: 52rpx;
  border: 5rpx solid #FFFDF7;
  border-radius: 50%;
  background: #2E452C;
}

.avatar-camera-mark::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 15rpx;
  width: 20rpx;
  height: 15rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 5rpx;
}

.avatar-camera-mark::after {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  width: 6rpx;
  height: 6rpx;
  border: 2rpx solid #FFFFFF;
  border-radius: 50%;
}

.profile-avatar-copy {
  min-width: 0;
}

.profile-avatar-title {
  margin-bottom: 10rpx;
  color: #242920;
  font-size: 28rpx;
  font-weight: 900;
}

.profile-avatar-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 18rpx;
}

.avatar-action {
  width: 100%;
  min-height: 78rpx;
  font-size: 23rpx;
}

.profile-form-block {
  margin-top: 30rpx;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.label {
  color: #596057;
  font-size: 25rpx;
  font-weight: 800;
}

.profile-name-input {
  background: #EEF3EA;
}

.profile-role-display {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
}

.profile-role-option {
  display: flex;
  min-height: 86rpx;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.68);
  border-radius: 999rpx;
  color: #596057;
  background: #FFFDF7;
  font-size: 25rpx;
  font-weight: 800;
}

.profile-role-option.is-active {
  color: #FFFFFF;
  border-color: #2E452C;
  background: #2E452C;
  box-shadow: 0 12rpx 24rpx rgba(63, 101, 72, 0.16);
}

.profile-role-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.profile-role-leaf {
  border: 4rpx solid currentColor;
  border-radius: 80% 10% 80% 10%;
  transform: rotate(-22deg);
}

.profile-role-person::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 0;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.profile-role-person::after {
  content: "";
  position: absolute;
  left: 3rpx;
  bottom: 0;
  width: 22rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-radius: 16rpx 16rpx 4rpx 4rpx;
}

.profile-role-note {
  margin-top: 14rpx;
  color: #7C837A;
  font-size: 21rpx;
  line-height: 1.6;
}

.profile-quota-panel {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 30rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(63, 101, 72, 0.14);
  border-radius: 28rpx;
  background: #FFFDF7;
}

.quota-panel-icon {
  display: flex;
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #FFFFFF;
  background: #2E452C;
  font-size: 23rpx;
}

.quota-panel-copy {
  flex: 1;
  min-width: 0;
}

.quota-panel-title {
  margin-bottom: 12rpx;
  color: #2E452C;
  font-size: 27rpx;
  font-weight: 900;
}

.quota-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 0;
  color: #596057;
  font-size: 23rpx;
}

.quota-value {
  color: #2E452C;
  font-weight: 800;
  text-align: right;
}

.save-btn {
  width: 100%;
  margin-top: 34rpx;
}

@media (max-width: 360px) {
  .profile-edit-sheet {
    padding-right: 28rpx;
    padding-left: 28rpx;
  }

  .profile-avatar-editor {
    align-items: flex-start;
    flex-direction: column;
  }

  .avatar-picker {
    align-self: center;
  }

  .profile-avatar-copy {
    text-align: center;
  }

  .profile-avatar-actions {
    grid-template-columns: minmax(0, 1fr);
  }

  .profile-role-display {
    grid-template-columns: minmax(0, 1fr);
  }
}
