.companion-badges-page {
  min-height: 100vh;
  background: #FFFDF7;
}

.companion-badges-header {
  padding: 34rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.76);
  border-radius: 36rpx;
  background: linear-gradient(145deg, #EEF3EA 0%, #ffffff 64%, #f2f7ef 100%);
  box-shadow: 0 18rpx 52rpx rgba(90, 48, 62, 0.08);
}

.companion-badges-profile {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.companion-badges-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 92rpx;
  width: 92rpx;
  height: 92rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  box-sizing: border-box;
  box-shadow: 0 10rpx 26rpx rgba(46, 69, 44, 0.13);
}

.companion-badges-avatar-text {
  color: #ffffff;
  background: #2E452C;
  font-size: 30rpx;
  font-weight: 900;
}

.companion-badges-profile-copy {
  min-width: 0;
  flex: 1 1 auto;
}

.companion-badges-kicker,
.companion-badges-section-kicker {
  color: #2E452C;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.14em;
}

.companion-badges-title {
  margin-top: 7rpx;
  color: #242920;
  font-size: 37rpx;
  font-weight: 900;
  line-height: 1.2;
}

.companion-badges-copy {
  margin-top: 12rpx;
  color: #7C837A;
  font-size: 22rpx;
  line-height: 1.55;
}

.companion-badges-progress-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
}

.companion-badges-progress-copy {
  flex: 0 0 auto;
  color: #3F6548;
  font-size: 21rpx;
  font-weight: 850;
}

.companion-badges-progress-track {
  overflow: hidden;
  height: 15rpx;
  flex: 1 1 auto;
  border-radius: 999rpx;
  background: #e3eee0;
}

.companion-badges-progress-fill {
  min-width: 8rpx;
  max-width: 100%;
  height: 100%;
  border-radius: inherit;
  background: #3F6548;
}

.companion-badges-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.companion-badges-summary-card {
  min-width: 0;
  padding: 24rpx 12rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.72);
  border-radius: 26rpx;
  background: #ffffff;
  text-align: center;
}

.companion-badges-summary-card.is-equipped {
  border-color: rgba(63, 101, 72, 0.25);
  background: #EEF3EA;
}

.companion-badges-summary-card.is-locked {
  background: #F6F1E7;
}

.companion-badges-summary-value {
  color: #242920;
  font-size: 36rpx;
  font-weight: 900;
}

.companion-badges-summary-label {
  margin-top: 6rpx;
  color: #7C837A;
  font-size: 20rpx;
  font-weight: 700;
}

.companion-badges-section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin: 38rpx 4rpx 18rpx;
}

.companion-badges-section-heading > view:first-child {
  min-width: 0;
  flex: 1 1 auto;
}

.companion-badges-section-heading.is-wall {
  margin-top: 42rpx;
}

.companion-badges-section-title {
  margin-top: 7rpx;
  color: #242920;
  font-size: 31rpx;
  font-weight: 900;
}

.companion-badges-section-note {
  flex: 0 0 auto;
  color: #7C837A;
  font-size: 20rpx;
}

.companion-badges-showcase {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.74);
  border-radius: 32rpx;
  background: linear-gradient(145deg, #EEF3EA, #ffffff);
}

.companion-badges-showcase-item {
  min-width: 0;
  padding: 20rpx 10rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.82);
  text-align: center;
}

.companion-badges-showcase-icon,
.companion-badge-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  margin: 0 auto;
  border-radius: 50%;
  color: #ffffff;
  background: linear-gradient(145deg, #2E452C, #9A715B);
  box-shadow: 0 9rpx 24rpx rgba(63, 101, 72, 0.18);
  font-size: 22rpx;
  font-weight: 900;
}

.companion-badges-showcase-name {
  overflow: hidden;
  margin-top: 14rpx;
  color: #242920;
  font-size: 22rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.companion-badges-showcase-state {
  margin-top: 7rpx;
  color: #2E452C;
  font-size: 20rpx;
  font-weight: 750;
}

.companion-badges-showcase-empty {
  display: block;
  color: #7C837A;
  font-size: 22rpx;
  line-height: 1.65;
  text-align: center;
}

.companion-badge-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.companion-badge-card {
  position: relative;
  min-width: 0;
  min-height: 300rpx;
  padding: 28rpx 22rpx 24rpx;
  border: 1rpx solid rgba(232, 225, 211, 0.74);
  border-radius: 30rpx;
  box-sizing: border-box;
  background: #ffffff;
  text-align: center;
}

.companion-badge-card.is-equipped {
  border-color: rgba(63, 101, 72, 0.45);
  background: linear-gradient(150deg, #EEF3EA, #ffffff);
  box-shadow: 0 14rpx 34rpx rgba(63, 101, 72, 0.1);
}

.companion-badge-card.is-locked {
  background: #F6F1E7;
}

.companion-badge-card.is-locked .companion-badge-icon,
.companion-badge-card.is-locked .companion-badge-name,
.companion-badge-card.is-locked .companion-badge-description {
  opacity: 0.48;
}

.companion-badge-card-number {
  position: absolute;
  top: 18rpx;
  right: 20rpx;
  color: rgba(63, 101, 72, 0.22);
  font-size: 27rpx;
  font-weight: 900;
}

.companion-badge-icon {
  width: 86rpx;
  height: 86rpx;
}

.companion-badge-card.is-unlocked:not(.is-equipped) .companion-badge-icon {
  background: linear-gradient(145deg, #3F6548, #8eb086);
}

.companion-badge-card.is-locked .companion-badge-icon {
  color: #596057;
  background: #E7EFE4;
  box-shadow: none;
}

.companion-badge-image {
  width: 100%;
  height: 100%;
}

.companion-badge-name {
  margin-top: 16rpx;
  color: #242920;
  font-size: 25rpx;
  font-weight: 900;
}

.companion-badge-description {
  margin-top: 10rpx;
  color: #7C837A;
  font-size: 20rpx;
  line-height: 1.5;
}

.companion-badge-state {
  display: inline-flex;
  margin-top: 17rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #3F6548;
  background: #e8f6e4;
  font-size: 20rpx;
  font-weight: 800;
}

.companion-badge-card.is-equipped .companion-badge-state {
  color: #3F6548;
  background: #E7EFE4;
}

.companion-badge-card.is-locked .companion-badge-state {
  color: #596057;
  background: #E7EFE4;
}

.companion-badges-empty-state {
  padding: 62rpx 38rpx;
  border: 1rpx dashed #E8E1D3;
  border-radius: 34rpx;
  background: #ffffff;
  text-align: center;
}

.companion-badges-empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto;
  border-radius: 50%;
  color: #2E452C;
  background: #EEF3EA;
  font-size: 34rpx;
}

.companion-badges-empty-title {
  margin-top: 24rpx;
  color: #242920;
  font-size: 30rpx;
  font-weight: 900;
}

.companion-badges-empty-copy {
  max-width: 520rpx;
  margin: 14rpx auto 0;
  color: #7C837A;
  font-size: 23rpx;
  line-height: 1.65;
}

@media (max-width: 340px) {
  .companion-badge-grid,
  .companion-badges-summary-grid,
  .companion-badges-showcase {
    grid-template-columns: minmax(0, 1fr);
  }

  .companion-badges-summary-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18rpx;
    padding: 20rpx 24rpx;
    text-align: left;
  }

  .companion-badges-showcase-item {
    display: grid;
    grid-template-columns: 70rpx minmax(0, 1fr);
    align-items: center;
    column-gap: 16rpx;
    text-align: left;
  }

  .companion-badges-showcase-icon {
    grid-row: 1 / span 2;
    width: 70rpx;
    height: 70rpx;
    margin: 0;
  }

  .companion-badges-showcase-name,
  .companion-badges-showcase-state {
    margin-top: 0;
  }
}
