.sponsor-rules-page {
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
}

.rules-settings-header {
  margin-bottom: 24rpx;
}

.rules-page-title {
  margin-top: 18rpx;
  color: #711e3c;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.12;
  letter-spacing: -1rpx;
}

.rules-page-subtitle {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.55;
}

.rules-hero-card {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.12);
  border-radius: 30rpx;
  background: linear-gradient(135deg, #fff0f2 0%, #fff9f5 72%, #f6eee7 100%);
  box-shadow: 0 18rpx 44rpx rgba(113, 30, 60, 0.08);
}

.rules-hero-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 80rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: #8f3653;
  box-shadow: 0 12rpx 26rpx rgba(143, 54, 83, 0.22);
  font-size: 42rpx;
  font-weight: 800;
}

.rules-hero-copy {
  min-width: 0;
  flex: 1 1 auto;
}

.rules-hero-kicker {
  color: #9f4038;
  font-size: 21rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.rules-hero-title {
  margin: 7rpx 0 8rpx;
  color: #22191b;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.35;
}

.rules-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.rules-summary-card {
  min-width: 0;
  padding: 22rpx 14rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.5);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(125, 47, 73, 0.06);
}

.rules-summary-icon,
.rules-field-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-weight: 900;
}

.rules-summary-icon {
  width: 52rpx;
  height: 52rpx;
  margin: 0 auto 10rpx;
  font-size: 23rpx;
}

.rules-summary-value {
  overflow: hidden;
  color: #711e3c;
  font-size: 34rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coral {
  color: #8d302b;
  background: #ffdad6;
}

.berry {
  color: #711e3c;
  background: #f2dfe5;
}

.sage {
  color: #2b4429;
  background: #dce9d9;
}

.gold {
  color: #7c5420;
  background: #fff0d9;
}

.rules-section-list {
  margin-top: 34rpx;
}

.rules-section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 38rpx;
  margin-bottom: 16rpx;
}

.rules-section-heading > view:first-child {
  min-width: 0;
  flex: 1 1 auto;
}

.rules-section-heading .section-title {
  margin-bottom: 4rpx;
}

.rules-section-badge {
  flex: 0 0 auto;
  max-width: 220rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #2b4429;
  background: #e7f0e4;
  font-size: 20rpx;
  font-weight: 800;
  text-align: center;
}

.rules-section-badge.danger {
  color: #93000a;
  background: #ffdad6;
}

.rules-section-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(217, 192, 197, 0.48);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 16rpx 38rpx rgba(125, 47, 73, 0.07);
}

.rules-field-row {
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 180rpx;
  align-items: center;
  gap: 18rpx;
  min-height: 112rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f2e4e7;
}

.rules-field-row.last {
  border-bottom: 0;
}

.rules-field-icon {
  width: 64rpx;
  height: 64rpx;
  font-size: 27rpx;
}

.rules-field-copy {
  min-width: 0;
}

.rules-field-title {
  color: #22191b;
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1.35;
}

.rules-input-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  min-width: 0;
  min-height: 70rpx;
  padding: 0 18rpx;
  border: 1rpx solid #e7d6d8;
  border-radius: 18rpx;
  background: #fff8f8;
}


.rules-input-unit {
  flex: 0 0 auto;
  color: #8f3653;
  font-size: 25rpx;
  font-weight: 800;
}

.rules-money-input {
  width: 112rpx;
  min-width: 0;
  height: 66rpx;
  color: #711e3c;
  font-size: 29rpx;
  font-weight: 900;
  text-align: right;
}

.rules-input-wrap.compact {
  width: 146rpx;
  box-sizing: border-box;
}

.streak-day-mark {
  display: flex;
  align-items: baseline;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  color: #8d302b;
  background: #ffdad6;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.streak-day-mark text {
  margin-left: 2rpx;
  font-size: 17rpx;
}

.streak-day-mark.active {
  color: #711e3c;
  background: #f2dfe5;
}

.streak-day-mark.mature {
  color: #2b4429;
  background: #dce9d9;
}

.level-progress-summary {
  padding: 26rpx;
  border: 1rpx solid rgba(65, 92, 62, 0.18);
  border-radius: 28rpx;
  background: linear-gradient(140deg, #f7fbf5 0%, #fff9f5 100%);
}

.level-progress-summary.over-limit {
  border-color: rgba(186, 26, 26, 0.2);
  background: #fff7f6;
}

.level-progress-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.level-progress-topline > view:first-child {
  min-width: 0;
  flex: 1 1 auto;
}

.level-progress-title {
  color: #22191b;
  font-size: 28rpx;
  font-weight: 850;
}

.level-progress-number {
  flex: 0 0 auto;
  color: #711e3c;
  font-size: 28rpx;
  font-weight: 900;
}

.level-progress-track {
  overflow: hidden;
  height: 16rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: #efdee1;
}

.level-progress-fill {
  min-width: 8rpx;
  max-width: 100%;
  height: 100%;
  border-radius: inherit;
  background: #415c3e;
  transition: width 180ms ease;
}

.limit-warning {
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  color: #93000a;
  background: #ffdad6;
  font-size: 22rpx;
  font-weight: 750;
}

.level-rule-list {
  display: grid;
  gap: 18rpx;
  margin-top: 18rpx;
}

.level-rule-card {
  padding: 24rpx;
}

.level-card-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.level-order {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 54rpx;
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #8f3653;
  font-size: 24rpx;
  font-weight: 900;
}

.level-meta {
  min-width: 0;
  flex: 1 1 auto;
}

.level-inputs {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.level-input-field {
  min-width: 0;
}

.level-input-label {
  margin-bottom: 8rpx;
  color: #544246;
  font-size: 21rpx;
  font-weight: 750;
}

.level-input-shell {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 72rpx;
  padding: 0 18rpx;
  border: 1rpx solid #e7d6d8;
  border-radius: 18rpx;
  color: #8f3653;
  background: #fff8f8;
  font-size: 23rpx;
  font-weight: 800;
}

.level-number-input {
  min-width: 0;
  height: 68rpx;
  flex: 1 1 auto;
  color: #22191b;
  font-size: 27rpx;
  font-weight: 850;
}

.level-number-input.reward {
  text-align: right;
}

.rules-save-dock {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(217, 192, 197, 0.7);
  background: rgba(255, 248, 248, 0.96);
  box-shadow: 0 -14rpx 40rpx rgba(56, 46, 48, 0.08);
}

.rules-save-note {
  margin-bottom: 9rpx;
  color: #877276;
  font-size: 20rpx;
  text-align: center;
}

.rules-save-button {
  width: 100%;
  margin: 0;
}

@media (max-width: 360px) {
  .rules-summary-grid,
  .rules-field-row,
  .level-inputs {
    grid-template-columns: minmax(0, 1fr);
  }

  .rules-summary-card {
    display: grid;
    grid-template-columns: 52rpx minmax(0, 1fr);
    align-items: center;
    column-gap: 14rpx;
    text-align: left;
  }

  .rules-summary-icon {
    grid-row: 1 / span 2;
    margin: 0;
  }

  .rules-field-row {
    gap: 12rpx;
  }

  .rules-input-wrap,
  .rules-input-wrap.compact {
    width: 100%;
    box-sizing: border-box;
  }

  .rules-money-input {
    width: 100%;
  }

  .rules-section-heading,
  .level-progress-topline {
    align-items: flex-start;
    flex-direction: column;
  }

  .rules-section-badge {
    max-width: 100%;
  }
}
