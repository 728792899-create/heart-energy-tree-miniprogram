.sponsor-page {
  background: #FFFDF7;
}

.sponsor-manager-header {
  position: relative;
  padding-top: 42rpx;
  padding-bottom: 36rpx;
  border-bottom: 1rpx solid rgba(63, 101, 72, 0.08);
  background: linear-gradient(145deg, #FFFDF7 0%, #faecef 100%);
}

.sponsor-manager-profile {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding-right: 128rpx;
}

.sponsor-manager-heading {
  min-width: 0;
}

.companion-title {
  margin: 12rpx 0 8rpx;
  color: #242920;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.avatar-wrap {
  flex: 0 0 92rpx;
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  background: #E7EFE4;
  box-shadow: 0 12rpx 28rpx rgba(63, 101, 72, 0.14);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  color: #3F6548;
  font-size: 34rpx;
  font-weight: 900;
}

.sponsor-settings-button {
  position: absolute;
  top: 42rpx;
  right: 28rpx;
  width: 92rpx;
  min-height: 92rpx;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  border: 1rpx solid rgba(63, 101, 72, 0.14);
  border-radius: 24rpx;
  color: #3F6548;
  background: rgba(255, 255, 255, 0.82);
  font-size: 20rpx;
}

.settings-gear {
  font-size: 30rpx;
}

.sponsor-manager-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin: 24rpx 0 28rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: #f1e1e6;
}

.sponsor-manager-tab {
  min-width: 0;
  min-height: 78rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 999rpx;
  color: #7f7075;
  background: transparent;
  font-size: 26rpx;
  font-weight: 800;
}

.sponsor-manager-tab.active {
  color: #3F6548;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(63, 101, 72, 0.1);
}

.manager-tab-count {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #ffffff;
  background: #3F6548;
  font-size: 20rpx;
}

.sponsor-task-overview {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-kicker {
  color: #3F6548;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.task-overview-title {
  margin-top: 6rpx;
  color: #242920;
  font-size: 36rpx;
  font-weight: 900;
}

.task-overview-seal {
  min-width: 70rpx;
  height: 70rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.task-overview-seal.pending {
  background: #3F6548;
  box-shadow: 0 12rpx 26rpx rgba(162, 60, 94, 0.2);
}

.task-overview-seal.clear {
  background: #6A725F;
}

.sponsor-pending-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-color: rgba(63, 101, 72, 0.12);
  background: linear-gradient(145deg, #FFFDF7, #fbedef);
}

.fund-task-card {
  background: linear-gradient(145deg, #FFFDF7, #f7eaed);
}

.pending-card-heading {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.pending-card-icon {
  flex: 0 0 66rpx;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #ffffff;
  background: #3F6548;
  font-size: 30rpx;
  font-weight: 900;
}

.fund-icon {
  background: #3F6548;
}

.pending-card-copy {
  flex: 1;
  min-width: 0;
}

.pending-card-title {
  color: #242920;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.35;
}

.pending-status-badge {
  flex: 0 0 auto;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  color: #8e3553;
  background: #f6dce4;
  font-size: 21rpx;
  font-weight: 800;
}

.pending-card-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
}

.pending-card-summary.fund-summary {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.summary-label {
  color: #596057;
  font-size: 21rpx;
}

.summary-value {
  margin-top: 6rpx;
  color: #596057;
  font-size: 27rpx;
  font-weight: 900;
}

.sponsor-task-actions {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.task-primary-action,
.task-secondary-action {
  width: 100%;
  min-width: 0;
}

.fund-action {
  background: #3F6548;
}

.risk-note {
  margin-top: 18rpx;
  color: #596057;
  font-size: 21rpx;
  font-style: italic;
  line-height: 1.5;
}

.sponsor-empty-task {
  padding: 44rpx 28rpx;
  text-align: center;
}

.empty-task-mark {
  margin-bottom: 12rpx;
  color: #3F6548;
  font-size: 58rpx;
}

.sponsor-insight-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  min-width: 0;
  padding: 24rpx 12rpx;
  text-align: center;
}

.stat-number {
  color: #3F6548;
  font-size: 40rpx;
  font-weight: 900;
}

.tree-card {
  margin-bottom: 26rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 900;
}

.coin {
  color: #3F6548;
  font-size: 36rpx;
  font-weight: 900;
}

.progress {
  overflow: hidden;
  height: 16rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: #E7EFE4;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #3F6548, #A88454);
}

.manager-link-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.manager-link-card {
  min-width: 0;
  min-height: 92rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(63, 101, 72, 0.12);
  border-radius: 24rpx;
  color: #6f2b43;
  background: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
}

.weekly-recap-entry {
  width: 100%;
  min-height: 96rpx;
  margin: 0 0 26rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #3F6548;
  background: #E7EFE4;
}

@media (max-width: 360px) {
  .sponsor-manager-profile {
    align-items: flex-start;
    padding-right: 94rpx;
  }

  .sponsor-manager-tabs,
  .pending-card-summary,
  .pending-card-summary.fund-summary,
  .sponsor-task-actions,
  .sponsor-insight-grid,
  .manager-link-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .sponsor-manager-tabs {
    border-radius: 28rpx;
  }

  .pending-card-heading {
    flex-wrap: wrap;
  }

  .pending-status-badge {
    margin-left: 84rpx;
  }
}
