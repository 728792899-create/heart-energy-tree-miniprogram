.companion-history-page {
  min-height: 100vh;
  background: #fff8f8;
}

.companion-history-header {
  position: relative;
  overflow: hidden;
  padding: 38rpx 34rpx 34rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.76);
  border-radius: 36rpx;
  background: linear-gradient(145deg, #fff0f2 0%, #fff8f8 68%, #f4f8f1 100%);
  box-shadow: 0 18rpx 54rpx rgba(90, 48, 62, 0.08);
}

.companion-history-ornament {
  position: absolute;
  top: 28rpx;
  right: 30rpx;
  width: 92rpx;
  height: 86rpx;
  opacity: 0.18;
  transform: rotate(18deg);
}

.companion-history-footprint {
  position: absolute;
  width: 26rpx;
  height: 38rpx;
  border-radius: 58% 58% 48% 48%;
  background: #8f3653;
}

.companion-history-footprint::before,
.companion-history-footprint::after {
  position: absolute;
  content: '';
  width: 10rpx;
  height: 12rpx;
  border-radius: 50%;
  background: inherit;
}

.companion-history-footprint::before {
  top: -10rpx;
  left: 0;
}

.companion-history-footprint::after {
  top: -13rpx;
  right: 0;
}

.footprint-one {
  left: 10rpx;
  bottom: 6rpx;
}

.footprint-two {
  top: 2rpx;
  right: 8rpx;
  transform: rotate(10deg);
}

.companion-history-profile {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-right: 88rpx;
}

.companion-history-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 78rpx;
  width: 78rpx;
  height: 78rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(113, 30, 60, 0.12);
}

.companion-history-avatar-text {
  color: #ffffff;
  background: #8f3653;
  font-size: 28rpx;
  font-weight: 900;
}

.companion-history-profile-copy {
  min-width: 0;
  flex: 1 1 auto;
}

.companion-history-kicker,
.companion-history-section-kicker {
  color: #8f3653;
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 0.16em;
}

.companion-history-title {
  margin-top: 7rpx;
  color: #22191b;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.18;
}

.companion-history-copy {
  position: relative;
  z-index: 1;
  max-width: 580rpx;
  margin-top: 24rpx;
  color: #544246;
  font-size: 25rpx;
  line-height: 1.7;
}

.companion-history-notice {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  color: #334d31;
  background: rgba(204, 235, 197, 0.55);
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.55;
}

.companion-history-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.companion-history-summary-card {
  min-width: 0;
  padding: 24rpx 14rpx 22rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.72);
  border-radius: 28rpx;
  background: #ffffff;
  text-align: center;
}

.companion-history-summary-card.is-reward {
  background: #fff7ed;
}

.companion-history-summary-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  margin: 0 auto 12rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #415c3e;
  font-size: 22rpx;
  font-weight: 900;
}

.companion-history-summary-icon.is-timer {
  color: #76211c;
  background: #ffdad6;
}

.companion-history-summary-icon.is-reward {
  color: #7d4c00;
  background: #ffe1aa;
}

.companion-history-summary-value {
  overflow: hidden;
  color: #22191b;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.companion-history-summary-label {
  margin-top: 7rpx;
  color: #877276;
  font-size: 20rpx;
  font-weight: 700;
}

.companion-history-section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin: 38rpx 4rpx 18rpx;
}

.companion-history-section-heading > view:first-child {
  min-width: 0;
  flex: 1 1 auto;
}

.companion-history-section-title {
  margin-top: 7rpx;
  color: #22191b;
  font-size: 32rpx;
  font-weight: 900;
}

.companion-history-latest {
  flex: 0 0 auto;
  max-width: 260rpx;
  color: #877276;
  font-size: 20rpx;
  text-align: right;
}

.companion-history-entry-list {
  display: grid;
  gap: 22rpx;
}

.companion-history-entry-card {
  overflow: hidden;
  border: 1rpx solid rgba(217, 192, 197, 0.72);
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(56, 46, 48, 0.06);
}

.companion-history-entry-media {
  position: relative;
  min-height: 250rpx;
  background: #fbeaec;
}

.companion-history-entry-image {
  display: block;
  width: 100%;
  height: 300rpx;
}

.companion-history-entry-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  min-height: 250rpx;
  padding: 36rpx;
  box-sizing: border-box;
  color: #877276;
  background: linear-gradient(145deg, #fff0f2 0%, #f4f8f1 100%);
}

.companion-history-placeholder-leaf {
  width: 56rpx;
  height: 78rpx;
  border-radius: 80% 0 80% 0;
  background: rgba(65, 92, 62, 0.22);
  transform: rotate(32deg);
}

.companion-history-placeholder-copy {
  margin-top: 22rpx;
  font-size: 22rpx;
}

.companion-history-status-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #544246;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 6rpx 18rpx rgba(56, 46, 48, 0.08);
  font-size: 20rpx;
  font-weight: 850;
}

.companion-history-status-badge.is-success {
  color: #2b4429;
  background: #e8f6e4;
}

.companion-history-status-badge.is-pending {
  color: #76211c;
  background: #ffdad6;
}

.companion-history-status-badge.is-muted {
  color: #544246;
  background: #efdee1;
}

.companion-history-entry-body {
  padding: 28rpx;
}

.companion-history-entry-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.companion-history-entry-heading > view:first-child {
  min-width: 0;
  flex: 1 1 auto;
}

.companion-history-date {
  color: #22191b;
  font-size: 29rpx;
  font-weight: 900;
}

.companion-history-duration {
  margin-top: 6rpx;
  color: #877276;
  font-size: 21rpx;
}

.companion-history-entry-number {
  color: rgba(143, 54, 83, 0.22);
  font-size: 45rpx;
  font-weight: 900;
  line-height: 1;
}

.companion-history-note {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-left: 5rpx solid #d9c0c5;
  border-radius: 0 18rpx 18rpx 0;
  color: #544246;
  background: #fff8f8;
  font-size: 24rpx;
  font-style: italic;
  line-height: 1.65;
}

.companion-history-reward-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  color: #7d2745;
  background: #fff0f2;
  font-size: 21rpx;
  font-weight: 850;
}

.companion-history-review-note,
.companion-history-care-note {
  margin-top: 16rpx;
  color: #334d31;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.55;
}

.companion-history-care-note {
  color: #877276;
  font-weight: 500;
}

.companion-history-empty-state {
  padding: 62rpx 38rpx;
  border: 1rpx dashed #d9c0c5;
  border-radius: 34rpx;
  background: #ffffff;
  text-align: center;
}

.companion-history-empty-seal {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto;
  border-radius: 50%;
  color: #8f3653;
  background: #fff0f2;
  font-size: 40rpx;
}

.companion-history-empty-title {
  margin-top: 24rpx;
  color: #22191b;
  font-size: 30rpx;
  font-weight: 900;
}

.companion-history-empty-copy {
  max-width: 520rpx;
  margin: 14rpx auto 0;
  color: #877276;
  font-size: 23rpx;
  line-height: 1.65;
}

@media (max-width: 360px) {
  .companion-history-summary-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .companion-history-summary-card {
    display: grid;
    grid-template-columns: 54rpx minmax(0, 1fr);
    align-items: center;
    column-gap: 16rpx;
    padding: 20rpx 22rpx;
    text-align: left;
  }

  .companion-history-summary-icon {
    grid-row: 1 / span 2;
    margin: 0;
  }

  .companion-history-section-heading {
    align-items: flex-start;
    flex-direction: column;
  }

  .companion-history-latest {
    max-width: 100%;
    text-align: left;
  }

  .companion-history-reward-line {
    align-items: flex-start;
    flex-direction: column;
  }
}
