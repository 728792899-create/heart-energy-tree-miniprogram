.history-page {
  padding-top: 20rpx;
}

.history-journal-header {
  position: relative;
  overflow: hidden;
  padding: 48rpx 38rpx 46rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.1);
  border-radius: 38rpx;
  text-align: center;
  background: linear-gradient(150deg, #FFF0F2 0%, #FFF8F8 54%, #F8E6EC 100%);
}

.history-journal-ornament {
  position: relative;
  width: 116rpx;
  height: 88rpx;
  margin: 0 auto 22rpx;
}

.history-footprint {
  position: absolute;
  width: 34rpx;
  height: 54rpx;
  border: 5rpx solid #8F3653;
  border-radius: 50% 50% 44% 44%;
  transform: rotate(-22deg);
}

.history-footprint::before,
.history-footprint::after {
  content: "";
  position: absolute;
  top: -18rpx;
  width: 10rpx;
  height: 14rpx;
  border: 4rpx solid #8F3653;
  border-radius: 50%;
}

.history-footprint::before { left: -5rpx; }
.history-footprint::after { right: -5rpx; }
.history-footprint-one { left: 20rpx; bottom: 0; }
.history-footprint-two { right: 18rpx; top: 0; transform: rotate(18deg); opacity: 0.72; }

.history-journal-kicker,
.history-section-kicker {
  color: #9F4038;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.history-journal-title {
  max-width: 560rpx;
  margin: 14rpx auto 0;
  color: #22191B;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.3;
}

.history-journal-copy {
  max-width: 560rpx;
  margin: 18rpx auto 0;
  color: #877276;
  font-size: 24rpx;
  line-height: 1.65;
}

.history-summary-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.history-summary-card {
  min-width: 0;
  padding: 26rpx 22rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.55);
  border-radius: 26rpx;
  text-align: center;
  background: #FFF0F2;
}

.history-summary-reward {
  grid-column: 1 / -1;
  background: #FFFFFF;
}

.history-summary-label { color: #544246; font-size: 22rpx; font-weight: 800; }
.history-summary-value { margin-top: 8rpx; color: #8F3653; font-size: 46rpx; font-weight: 900; }
.history-summary-money { font-size: 38rpx; }
.history-summary-unit { margin-top: 4rpx; color: #877276; font-size: 20rpx; }

.history-section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin: 38rpx 0 18rpx;
}

.history-section-title { margin-top: 6rpx; color: #22191B; font-size: 34rpx; font-weight: 900; }
.history-entry-count { color: #877276; font-size: 22rpx; }
.history-entry-list { display: flex; flex-direction: column; gap: 22rpx; }

.history-entry-card {
  overflow: hidden;
  border: 1rpx solid rgba(217, 192, 197, 0.5);
  border-radius: 30rpx;
  background: #FFFFFF;
  box-shadow: 0 14rpx 34rpx rgba(125, 47, 73, 0.06);
}

.history-entry-media { position: relative; min-height: 220rpx; background: #F8E6EC; }
.history-entry-image { width: 100%; height: 260rpx; }
.history-entry-placeholder { min-height: 220rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16rpx; color: #877276; font-size: 22rpx; }
.history-placeholder-leaf { width: 44rpx; height: 62rpx; border: 5rpx solid #334D31; border-radius: 80% 10% 80% 10%; transform: rotate(35deg); }

.history-status-badge { position: absolute; right: 18rpx; top: 18rpx; min-height: 46rpx; padding: 0 18rpx; display: flex; align-items: center; border-radius: 999rpx; font-size: 21rpx; font-weight: 900; }
.history-status-badge.is-pending { color: #78540F; background: rgba(255, 241, 201, 0.94); }
.history-status-badge.is-success { color: #25613E; background: rgba(228, 244, 234, 0.94); }
.history-status-badge.is-muted { color: #8B343A; background: rgba(252, 235, 236, 0.94); }

.history-entry-body { padding: 26rpx; }
.history-entry-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.history-date { color: #22191B; font-size: 29rpx; font-weight: 900; }
.history-duration { margin-top: 6rpx; color: #877276; font-size: 22rpx; }
.history-entry-number { color: rgba(143, 54, 83, 0.18); font-size: 48rpx; font-weight: 900; line-height: 1; }
.history-note { margin-top: 20rpx; padding: 20rpx 22rpx; border-left: 6rpx solid #FF897E; border-radius: 0 18rpx 18rpx 0; color: #544246; background: #FFF8F8; font-size: 24rpx; line-height: 1.6; }
.history-reward-line { display: flex; align-items: center; justify-content: space-between; gap: 14rpx; margin-top: 18rpx; color: #8F3653; font-size: 22rpx; font-weight: 800; }
.history-review-note { margin-top: 14rpx; color: #544246; font-size: 22rpx; line-height: 1.55; }

.history-empty-state { padding: 58rpx 30rpx; border: 2rpx dashed rgba(143, 54, 83, 0.24); border-radius: 32rpx; text-align: center; background: #FFF0F2; }
.history-empty-seal { width: 84rpx; height: 84rpx; margin: 0 auto 20rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: #8F3653; background: #FFFFFF; font-size: 48rpx; }
.history-empty-title { color: #711E3C; font-size: 29rpx; font-weight: 900; }
.history-empty-copy { margin-top: 12rpx; color: #877276; font-size: 23rpx; line-height: 1.6; }

@media (max-width: 360px) {
  .history-summary-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .history-summary-reward {
    grid-column: auto;
  }

  .history-reward-line {
    align-items: flex-start;
    flex-direction: column;
  }
}
