<view class="page bind-page">
  <couple-hero
    compact
    eyebrow="暖棕小熊与奶白小兔 · {{inviteMode ? '收到邀请' : '第一次见面'}}"
    title="晨曦陪伴花园"
    subtitle="你负责好好照顾自己，我负责一直为你加油"
    role="couple"
  ></couple-hero>

  <view class="relationship-opening-card">
    <view class="relationship-heart-seal" aria-label="两个人的爱心印章">
      <view class="relationship-heart-shape"></view>
    </view>
    <view class="relationship-opening-kicker">{{inviteMode ? '这是另一半送来的邀请' : '这是你们'}}</view>
    <view class="relationship-opening-title">{{inviteMode ? '一起开启陪伴的第一天' : '开启陪伴的第一天'}}</view>
    <view class="relationship-opening-copy">{{inviteMode ? '接受这份邀请，从今天开始一起记录成长、鼓励和每一个认真兑现的约定。' : '种下一颗属于两个人的种子，期待在未来的日子里慢慢生根发芽。'}}</view>
  </view>

  <motion-scene
    scene-key="binding"
    reduced-motion="{{reducedMotion}}"
    compact
    aria-label="暖棕小熊与奶白小兔一起种下心动能量树"
  ></motion-scene>

  <view class="binding-form-card">
    <view class="binding-card-heading">
      <view>
        <view class="binding-mode-badge">{{inviteMode ? '专属邀请' : (canCreateSponsor ? '发起关系' : '等待邀请')}}</view>
        <view class="binding-form-title">{{inviteMode ? '加入这棵能量树' : (canCreateSponsor ? '种下我们的树' : '等待另一半来牵手')}}</view>
      </view>
      <view class="binding-leaf-mark" aria-hidden="true"></view>
    </view>

    <view class="binding-step-grid">
      <view class="binding-step-item">
        <view class="binding-step-index">01</view>
        <view class="binding-step-copy">
          <view class="binding-step-title">写下你的称呼</view>
          <view class="binding-step-note">这是另一半在花园里看到的名字</view>
        </view>
      </view>
      <view class="binding-step-item">
        <view class="binding-step-index">02</view>
        <view class="binding-step-copy">
          <view class="binding-step-title">{{inviteMode ? '接受专属邀请' : (canCreateSponsor ? '创建双人空间' : '打开邀请卡片')}}</view>
          <view class="binding-step-note">微信身份会安全地绑定到对应关系</view>
        </view>
      </view>
    </view>

    <view class="binding-field-shell">
      <view class="label">你的称呼</view>
      <input
        class="input binding-name-input"
        maxlength="16"
        placeholder="例如：小鹿 / 男朋友"
        value="{{displayName}}"
        aria-label="输入你在双人花园里的称呼"
        bindinput="onNameInput"
      />
    </view>

    <view wx:if="{{inviteMode}}" class="invite-card">
      <view class="invite-icon" aria-hidden="true">♡</view>
      <view class="invite-copy">
        <view class="invite-title">来自另一半的专属邀请</view>
        <view class="muted small">点击加入后，小程序会用你的微信身份进入这棵能量树。</view>
      </view>
    </view>

    <button wx:if="{{inviteMode}}" class="primary-btn submit-btn" loading="{{submitting}}" disabled="{{submitting || creating}}" aria-label="加入两个人的心动能量树" bindtap="submit">{{submitting ? '正在加入…' : '接受邀请并加入'}}</button>
    <button wx:elif="{{canCreateSponsor}}" class="primary-btn submit-btn" loading="{{creating}}" disabled="{{creating || submitting}}" aria-label="创建两个人的心动能量树" bindtap="createTree">{{creating ? '正在种下能量树…' : '创建并成为发起者'}}</button>
    <view wx:else class="empty invite-empty">
      <view class="invite-empty-title">还差一张专属邀请卡</view>
      <view>请让另一半在小程序“我的”页面点击邀请按钮，再从分享卡片进入这里。</view>
    </view>

    <view class="binding-identity-note">
      <view class="binding-lock-mark" aria-hidden="true"></view>
      <view class="muted small hint">身份绑定以微信 OpenID 为准，页面不会通过手动切换角色来决定权限。</view>
    </view>
  </view>
</view>
