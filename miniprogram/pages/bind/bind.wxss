.bind-page {
  padding-top: 20rpx;
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.relationship-opening-card {
  position: relative;
  overflow: hidden;
  margin-top: 24rpx;
  padding: 64rpx 42rpx 58rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.08);
  border-radius: 44rpx;
  text-align: center;
  background:
    radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.72) 0 12%, transparent 34%),
    linear-gradient(145deg, #FFF0F2 0%, #F8E6EC 58%, #FFF8F8 100%);
  box-shadow: 0 22rpx 54rpx rgba(125, 47, 73, 0.08);
}

.relationship-opening-card::before,
.relationship-opening-card::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.relationship-opening-card::before {
  width: 240rpx;
  height: 240rpx;
  left: -116rpx;
  top: -110rpx;
}

.relationship-opening-card::after {
  width: 180rpx;
  height: 180rpx;
  right: -86rpx;
  bottom: -88rpx;
}

.relationship-heart-seal {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 124rpx;
  height: 124rpx;
  margin: 0 auto 32rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.08);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 24rpx rgba(125, 47, 73, 0.09);
}

.relationship-heart-shape {
  position: relative;
  width: 48rpx;
  height: 42rpx;
  transform: rotate(-45deg);
  border-left: 6rpx solid #7D2745;
  border-bottom: 6rpx solid #7D2745;
  border-radius: 0 0 0 9rpx;
}

.relationship-heart-shape::before,
.relationship-heart-shape::after {
  content: "";
  position: absolute;
  border: 6rpx solid #7D2745;
  background: transparent;
}

.relationship-heart-shape::before {
  width: 30rpx;
  height: 42rpx;
  left: -6rpx;
  top: -26rpx;
  border-bottom: 0;
  border-radius: 30rpx 30rpx 0 0;
}

.relationship-heart-shape::after {
  width: 42rpx;
  height: 30rpx;
  right: -26rpx;
  bottom: -6rpx;
  border-left: 0;
  border-radius: 0 30rpx 30rpx 0;
}

.relationship-opening-kicker {
  position: relative;
  z-index: 1;
  color: #544246;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.relationship-opening-title {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  color: #711E3C;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -1rpx;
}

.relationship-opening-copy {
  position: relative;
  z-index: 1;
  max-width: 560rpx;
  margin: 24rpx auto 0;
  color: #877276;
  font-size: 25rpx;
  line-height: 1.75;
}

.binding-form-card {
  position: relative;
  overflow: hidden;
  margin-top: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.5);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 18rpx 46rpx rgba(125, 47, 73, 0.08);
}

.binding-form-card::after {
  content: "";
  position: absolute;
  right: -62rpx;
  top: -72rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 240, 242, 0.82);
}

.binding-card-heading {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.binding-mode-badge {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #7D2745;
  background: #FFF0F2;
  font-size: 21rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.binding-form-title {
  margin-top: 14rpx;
  color: #22191B;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.3;
}

.binding-leaf-mark {
  position: relative;
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E8F4E5;
}

.binding-leaf-mark::before,
.binding-leaf-mark::after {
  content: "";
  position: absolute;
  width: 24rpx;
  height: 38rpx;
  border: 4rpx solid #334D31;
  border-radius: 80% 10% 80% 10%;
  transform: rotate(38deg);
}

.binding-leaf-mark::before {
  left: 18rpx;
  top: 17rpx;
}

.binding-leaf-mark::after {
  right: 13rpx;
  top: 13rpx;
  transform: rotate(78deg) scale(0.82);
}

.binding-step-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.binding-step-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  min-width: 0;
  padding: 22rpx;
  border: 1rpx solid rgba(217, 192, 197, 0.38);
  border-radius: 24rpx;
  background: #FFF8F8;
}

.binding-step-index {
  flex: 0 0 44rpx;
  color: #9F4038;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.4;
}

.binding-step-copy {
  min-width: 0;
}

.binding-step-title {
  color: #22191B;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
}

.binding-step-note {
  margin-top: 8rpx;
  color: #877276;
  font-size: 20rpx;
  line-height: 1.5;
}

.binding-field-shell {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #FFF0F2;
}

.label {
  margin-bottom: 12rpx;
  color: #544246;
  font-size: 24rpx;
  font-weight: 800;
}

.binding-name-input {
  border-color: rgba(143, 54, 83, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.6);
}

.submit-btn {
  position: relative;
  z-index: 1;
  width: 100%;
  margin-top: 26rpx;
}

.invite-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.12);
  border-radius: 26rpx;
  background: linear-gradient(135deg, #FFF8F8, #F8E6EC);
}

.invite-icon {
  display: flex;
  flex: 0 0 68rpx;
  width: 68rpx;
  height: 68rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #8F3653;
  background: rgba(255, 255, 255, 0.86);
  font-size: 42rpx;
  line-height: 1;
}

.invite-copy {
  min-width: 0;
}

.invite-title {
  margin-bottom: 6rpx;
  color: #711E3C;
  font-size: 27rpx;
  font-weight: 900;
}

.invite-empty {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  padding: 32rpx 26rpx;
  line-height: 1.65;
}

.invite-empty-title {
  margin-bottom: 8rpx;
  color: #711E3C;
  font-size: 27rpx;
  font-weight: 900;
}

.binding-identity-note {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(217, 192, 197, 0.52);
}

.binding-lock-mark {
  position: relative;
  flex: 0 0 28rpx;
  width: 28rpx;
  height: 24rpx;
  margin-top: 8rpx;
  border: 3rpx solid #877276;
  border-radius: 6rpx;
}

.binding-lock-mark::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: -17rpx;
  width: 14rpx;
  height: 16rpx;
  border: 3rpx solid #877276;
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
}

.hint {
  flex: 1;
  min-width: 0;
  margin: 0;
  line-height: 1.6;
}

@media (max-width: 360px) {
  .relationship-opening-card {
    padding: 50rpx 28rpx 46rpx;
  }

  .relationship-opening-title {
    font-size: 42rpx;
  }

  .binding-form-card {
    padding: 26rpx;
  }

  .binding-step-grid {
    grid-template-columns: minmax(0, 1fr);
  }
}
