.reward-confirm-page {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 42rpx;
  background: #f5eeee;
}

.redemption-confirm-card {
  width: 100%;
  max-width: 694rpx;
  overflow: hidden;
  border: 1rpx solid rgba(143, 54, 83, 0.08);
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 28rpx 70rpx rgba(69, 48, 54, 0.15);
}

.confirm-card-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 36rpx 42rpx;
  text-align: center;
  background: #fff1f4;
  border-bottom: 1rpx solid rgba(143, 54, 83, 0.1);
}

.confirm-gift-mark {
  position: relative;
  width: 126rpx;
  height: 126rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  border-radius: 50%;
  color: #7d2f49;
  background: #edced8;
}

.gift-lid {
  position: absolute;
  top: 38rpx;
  left: 38rpx;
  width: 50rpx;
  height: 12rpx;
  border: 5rpx solid #7d2f49;
  border-radius: 5rpx 5rpx 0 0;
}

.gift-box {
  width: 54rpx;
  height: 42rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 5rpx solid #7d2f49;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
}

.confirm-title {
  color: #261d20;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.confirm-subtitle {
  margin-top: 14rpx;
  color: #655056;
  font-size: 28rpx;
  line-height: 1.55;
}

.confirm-card-body {
  padding: 40rpx 46rpx 34rpx;
}

.confirm-reward-preview {
  overflow: hidden;
  width: 100%;
  height: 292rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.11);
  border-radius: 20rpx;
  background: #f7f2f1;
  box-shadow: 0 8rpx 24rpx rgba(69, 48, 54, 0.07);
}

.confirm-reward-image {
  width: 100%;
  height: 100%;
}

.confirm-reward-name {
  margin-top: 30rpx;
  color: #261d20;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
  text-align: center;
}

.confirm-reward-description {
  margin: 12rpx auto 0;
  max-width: 560rpx;
  color: #78646a;
  font-size: 24rpx;
  line-height: 1.6;
  text-align: center;
}

.confirm-balance-sheet {
  margin-top: 34rpx;
  padding: 22rpx 30rpx;
  border: 1rpx solid rgba(143, 54, 83, 0.12);
  border-radius: 20rpx;
  background: #fff0f2;
}

.confirm-balance-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 20rpx;
  min-height: 54rpx;
}

.confirm-balance-label {
  min-width: 0;
  color: #655056;
  font-size: 27rpx;
}

.confirm-balance-value {
  color: #261d20;
  font-size: 29rpx;
  font-weight: 800;
  text-align: right;
}

.confirm-cost {
  color: #8f3653;
}

.confirm-balance-divider {
  height: 1rpx;
  margin: 12rpx 0;
  background: rgba(143, 54, 83, 0.12);
}

.confirm-current-balance {
  margin-top: 16rpx;
  color: #8a747a;
  font-size: 22rpx;
  text-align: right;
}

.confirm-action-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 22rpx;
  margin-top: 34rpx;
}

.confirm-cancel-btn,
.confirm-submit-btn {
  width: 100%;
  margin: 0;
}

@media (max-width: 360px) {
  .reward-confirm-page {
    padding-top: 20rpx;
  }

  .confirm-card-header {
    padding: 38rpx 24rpx 32rpx;
  }

  .confirm-card-body {
    padding: 30rpx 24rpx 26rpx;
  }

  .confirm-reward-preview {
    height: 250rpx;
  }

  .confirm-action-row {
    grid-template-columns: minmax(0, 1fr);
  }
}
